(* Three planar points q0, q1, q2 *)
Clear[q0, q1, q2];
q0 = {q0x, q0y};
q1 = {q1x, q1y};
q2 = {q2x, q2y};

d2  = q2 - 2 q1 + q0;
Eb  = d2.d2;

(* Gradients *)
g0 = Grad[Eb, {q0x, q0y}];
g1 = Grad[Eb, {q1x, q1y}];
g2 = Grad[Eb, {q2x, q2y}];

(* Export as a numerical function *)
gradFun = Function[
  {q0x, q0y, q1x, q1y, q2x, q2y},
  {g0, g1, g2}
];

(* Example usage *)
gradFun[0.0, 0.0, 0.5, 0.0, 1.0, 0.1]
      
