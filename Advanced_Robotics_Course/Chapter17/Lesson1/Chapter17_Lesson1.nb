m = 0.05;
k = 50;
c = 0.1;
g = 9.81;

(* y1[t], y2[t] are vertical positions of two masses;
   y1[t] is fixed at zero to model an anchor. *)
eqs = {
  y1[t] == 0,
  m y2''[t] + c y2'[t] + k (y2[t] - y1[t]) == -m g
};

ics = {
  y2[0] == 0,
  y2'[0] == 0
};

sol = NDSolve[
  Join[eqs, ics],
  {y1, y2},
  {t, 0, 2}
];

Plot[Evaluate[y2[t] /. sol], {t, 0, 2},
  PlotLabel -> "Second mass trajectory"]
      
