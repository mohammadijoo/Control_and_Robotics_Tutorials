(* Parameters and joint variables *)
l1 = Symbol["l1"];
l2 = Symbol["l2"];
q1 = Symbol["q1"];
q2 = Symbol["q2"];

(* End-effector position *)
px = l1 Cos[q1] + l2 Cos[q1 + q2];
py = l1 Sin[q1] + l2 Sin[q1 + q2];

(* Planar Jacobian: [omega_z; v_x; v_y] *)
J = {
   {1, 1},
   {D[px, q1], D[px, q2]},
   {D[py, q1], D[py, q2]}
} // Simplify;

MatrixForm[J]
      
