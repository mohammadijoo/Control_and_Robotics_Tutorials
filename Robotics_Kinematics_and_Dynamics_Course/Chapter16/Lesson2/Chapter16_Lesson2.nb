(* Symbols *)
Clear[x, y, phi, L1, L2, L3];
{x, y, phi, L1, L2, L3} = {x, y, phi, L1, L2, L3};

(* Geometry (example) *)
B1 = {0.0, 0.0};
B2 = {1.0, 0.0};
B3 = {0.5, Sqrt[3]/2.0};

P1 = {0.0, -0.2};
P2 = {0.2, 0.0};
P3 = {-0.2, 0.0};

p  = {x, y};
R[phi_] := { {Cos[phi], -Sin[phi]},
            {Sin[phi],  Cos[phi]} };
Smat = { {0, -1},
        {1,  0} };

legVec[B_, P_] := p + R[phi].P - B;

d1 = legVec[B1, P1];
d2 = legVec[B2, P2];
d3 = legVec[B3, P3];

Phi1 = d1.d1 - L1^2;
Phi2 = d2.d2 - L2^2;
Phi3 = d3.d3 - L3^2;

Phi  = {Phi1, Phi2, Phi3};
qVec = {L1, L2, L3};
xVec = {x, y, phi};

Jq = D[Phi, {qVec}]; (* dPhi/dq *)
Jx = D[Phi, {xVec}]; (* dPhi/dx *)

Jf = Simplify[-Inverse[Jx].Jq];
      
