m = 1.0;
g = 9.81;
R = 1.0;

(* Unknown functions: x(t), y(t), lambda(t) *)
eqs = {
   x''[t] == (2 lambda[t] x[t])/m,
   y''[t] == -g + (2 lambda[t] y[t])/m,
   x[t]^2 + y[t]^2 == R^2,
   x[t] x'[t] + y[t] y'[t] == 0
   };

(* Initial conditions on circle with tangential velocity *)
ics = {
   x[0] == R,    y[0] == 0,
   x'[0] == 0,   y'[0] == 0.5
   };

sol = NDSolve[Join[eqs, ics], {x, y, lambda}, {t, 0, 10}];

ParametricPlot[
  Evaluate[{x[t], y[t]} /. sol],
  {t, 0, 10}
]
      
