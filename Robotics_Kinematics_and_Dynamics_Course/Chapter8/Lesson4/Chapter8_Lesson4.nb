(* Link lengths *)
l1 = 1.0;
l2 = 0.7;

(* Joint ranges *)
th1min = -Pi; th1max = Pi;
th2min = -Pi; th2max = Pi;

x[th1_, th2_] := l1 Cos[th1] + l2 Cos[th1 + th2];
y[th1_, th2_] := l1 Sin[th1] + l2 Sin[th1 + th2];

ParametricPlot[
  Evaluate[{x[th1, th2], y[th1, th2]}],
  {th1, th1min, th1max},
  {th2, th2min, th2max},
  PlotPoints -> {60, 60},
  MaxRecursion -> 2,
  AspectRatio -> 1,
  Frame -> True,
  FrameLabel -> {"x [m]", "y [m]"},
  PlotLabel -> "Planar 2R Workspace (Mathematica)"
]

(* Analytic annulus check *)
rmin = Abs[l1 - l2];
rmax = l1 + l2;
RegionPlot[
  rmin <= Sqrt[x^2 + y^2] && Sqrt[x^2 + y^2] <= rmax,
  {x, -2, 2}, {y, -2, 2},
  AspectRatio -> 1,
  PlotPoints -> 60,
  FrameLabel -> {"x [m]", "y [m]"},
  PlotLabel -> "Analytic Annulus for 2R Workspace"
]
      
