
(* Parameters *)
a = 1.0;
k = 4.0;
cScale = 0.5;
c = cScale * (a + k);

(* Dummy learner: cubic residual *)
learner[x_] := 0.8 x^3;

nominalControl[x_] := -k x;

wrappedControl[x_] := Module[
  {uB, uL, bound},
  uB = nominalControl[x];
  uL = learner[x];
  bound = c Abs[x];
  If[Abs[uL] > bound,
     uL = Sign[uL] bound
  ];
  uB + uL
];

(* Example evaluation *)
x0 = 0.3;
u0 = wrappedControl[x0]
