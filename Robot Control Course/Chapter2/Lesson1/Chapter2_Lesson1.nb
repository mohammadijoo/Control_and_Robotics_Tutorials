
(* Parameters for a single joint error dynamics *)
zeta   = 0.7;
omegaN = 8.0;

eq = e''[t] + 2 zeta omegaN e'[t] + omegaN^2 e[t] == 0;
ic = {e[0] == 0.1, e'[0] == 0};

sol = NDSolve[{eq, ic}, e, {t, 0, 2}][[1]];

Plot[Evaluate[e[t] /. sol], {t, 0, 2},
  AxesLabel -> {"t", "e(t)"},
  PlotLabel -> "Joint error dynamics"
]
