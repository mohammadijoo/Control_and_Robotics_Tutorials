
J = 0.5;
b = 0.05;
qd = 1.0;
zeta = 0.7;
omegaN = 6.0;
Kp = J * omegaN^2;
Kd = 2 J zeta omegaN - b;

eqns = {
  q''[t] == (Kp (qd - q[t]) + Kd (0 - q'[t]) - b q'[t]) / J,
  q[0] == 0,
  q'[0] == 0
};

sol = NDSolve[eqns, q, {t, 0, 2}][[1]];

Plot[{q[t] /. sol, qd}, {t, 0, 2},
  PlotLegends -> {"q(t)", "qd"},
  AxesLabel -> {"t", "position"},
  GridLines -> Automatic
]
