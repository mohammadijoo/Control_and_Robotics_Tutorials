
J = 0.02;
b = 0.1;
k = 1.0;

A = { {0, 1},
     {-k/J, -b/J} };
B = { {0},
     {1/J} };
C = { {1, 0} };
D = { {0} };

sys = StateSpaceModel[{A, B, C, D}];

(* Solve dynamics with step input tau(t) = 1 *)
u[t_] := 1.0;
sol = SystemsModelSolve[sys, u, {t, 0, 5}];

qSol[t_] = OutputResponse[sys, u, t][[1]];
