
(* Define symbols *)
Clear[m, g, e, q, v, t];
m = 1.0; g = 9.81; e = 0.3;

(* Dynamics for free motion *)
eqs = {
  q'[t] == v[t],
  v'[t] == -g
};

(* Impact event: q(t) == 0 and v(t) < 0 *)
impactRule = {v[t] :> -e v[t]};

sol = NDSolve[
  {
    eqs,
    q[0] == 0.5,
    v[0] == -1.0,
    WhenEvent[q[t] == 0 && v[t] < 0,
      {v[t] -> -e v[t], q[t] -> 0}
    ]
  },
  {q, v},
  {t, 0, 3}
];

Plot[{q[t] /. sol[[1]]}, {t, 0, 3},
  PlotLegends -> {"q(t)"}
]
