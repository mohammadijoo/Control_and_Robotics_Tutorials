
(* Define saturation *)
sat[v_, vmin_, vmax_] = Min[Max[v, vmin], vmax];

(* Parameters *)
m = 1.0;
b = 0.2;
kp = 50.0;
kd = 10.0;
tauMax = 5.0;

(* Closed-loop dynamics for a single joint about q_ref = 0 *)
eq = q''[t] == (sat[-kp q[t] - kd q'[t], -tauMax, tauMax] - b q'[t])/m;

sol = NDSolve[
  {eq, q[0] == 0.5, q'[0] == 0.0},
  q, {t, 0, 5}
];

Plot[Evaluate[q[t] /. sol], {t, 0, 5},
     AxesLabel -> {"t", "q(t)"},
     PlotRange -> All]
