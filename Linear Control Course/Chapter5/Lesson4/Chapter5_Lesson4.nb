K = 2.0;
tau = 0.1;

y[t_] := K (1 - Exp[-t/tau]);

tDelay = -tau Log[0.5];
tRise = tau Log[9.0];
tSettle2 = -tau Log[0.02];

Print["t_d   = ", tDelay];
Print["t_r   = ", tRise];
Print["t_s2% = ", tSettle2];

Plot[y[t], {t, 0, 1},
  AxesLabel -> {"t", "y(t)"},
  Epilog -> {
    Dashed, Line[{ {0, K}, {1, K} }],
    Red, Dashed, Line[{ {tDelay, 0}, {tDelay, K} }],
    Blue, Dashed, Line[{ {tRise, 0}, {tRise, K} }],
    Green, Dashed, Line[{ {tSettle2, 0}, {tSettle2, K} }]
  }
]
