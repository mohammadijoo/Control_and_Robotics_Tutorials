(* Parameters *)
k = 5.0;
D = 3.0;
uMax = 1.0;
tFinal = 20.0;
x0 = 0.0;

sat[u_] := Max[-uMax, Min[u, uMax]];

eq = x'[t] == -x[t] + sat[-k x[t]] + D;
ic = x[0] == x0;

sol = NDSolve[{eq, ic}, x, {t, 0, tFinal}][[1]];

xFun[t_] := x[t] /. sol;
uCmd[t_] := -k xFun[t];
uSat[t_] := sat[uCmd[t]];

Plot[{xFun[t], uSat[t]}, {t, 0, tFinal},
 PlotLegends -> {"x(t)", "u_sat(t)"},
 AxesLabel -> {"t", ""}]
