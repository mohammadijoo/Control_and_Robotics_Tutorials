omegaN = 1.0;
zeta   = 0.2;
K      = 8.0;
uMax   = 2.0;

sat[v_] := Piecewise[{
  {-uMax, v <= -uMax},
  {v, -uMax < v < uMax},
  {uMax, v >= uMax}
}];

eqs = {
  x1'[t] == x2[t],
  x2'[t] == -2 zeta omegaN x2[t] - omegaN^2 x1[t] +
            omegaN^2 sat[K (1 - x1[t])],
  x1[0] == 0,
  x2[0] == 0
};

sol = NDSolve[eqs, {x1, x2}, {t, 0, 20}][[1]];

Plot[Evaluate[x1[t] /. sol], {t, 0, 20},
  AxesLabel -> {"t", "y(t)"},
  PlotLabel -> "Closed-loop response with saturation"
]
