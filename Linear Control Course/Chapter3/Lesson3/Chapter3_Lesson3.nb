J  = 0.01;
b  = 0.1;
Ra = 1.0;
La = 0.5;
Kt = 0.01;
Ke = 0.01;

theta = theta;
omega = omega;
ia    = ia;

eqs = {
  theta'[t] == omega[t],
  J*omega'[t] == Kt*ia[t] - b*omega[t],
  La*ia'[t] == 24.0 - Ra*ia[t] - Ke*omega[t],
  theta[0] == 0, omega[0] == 0, ia[0] == 0
};

sol = NDSolve[eqs, {theta, omega, ia}, {t, 0, 2}];

Plot[Evaluate[omega[t] /. sol], {t, 0, 2},
     AxesLabel -> {"t", "\[Omega](t)"}]
