Clear[RouthArray]
RouthArray[coeffs_List, eps_:10^-9] := Module[
  {n, m, R, i, j, a, b, c, d, col, signs, signChanges},
  n = Length[coeffs] - 1;
  m = Ceiling[(n + 1)/2];
  R = ConstantArray[0.0, {n + 1, m}];

  (* First two rows *)
  R[[1, 1 ;; ;; 2]] = coeffs[[1 ;; ;; 2]];
  If[Length[coeffs] > 1,
    R[[2, 1 ;; ;; 2]] = coeffs[[2 ;; ;; 2]];
  ];

  For[i = 3, i <= n + 1, i++,
    If[Abs[R[[i - 1, 1]]] < eps, R[[i - 1, 1]] = eps];
    For[j = 1, j <= m - 1, j++,
      a = R[[i - 1, 1]];
      b = R[[i - 2, 1]];
      c = R[[i - 2, j + 1]];
      d = R[[i - 1, j + 1]];
      R[[i, j]] = (a*c - b*d)/a;
    ];
  ];

  col = R[[All, 1]];
  col = col /. x_ /; Abs[x] < eps :> eps;
  signs = Sign[col];
  signChanges = Count[Partition[signs, 2, 1], {x_, y_} /; x*y < 0];

  {R, signChanges}
]

(* Example: p(s) = s^3 + 6 s^2 + 8 s + K *)
Clear[K]
coeffs = {1, 6, 8, K};
{R, nRHP} = RouthArray[coeffs];
R // MatrixForm
nRHP
