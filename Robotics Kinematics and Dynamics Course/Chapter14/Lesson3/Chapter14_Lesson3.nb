(* Parameters *)
J_l = 0.5;  J_m = 0.05;
b_l = 0.02; b_m = 0.01;
k   = 150.; d   = 0.5;
m   = 2.;   ell = 0.4; g = 9.81;
tau0 = 1.0;

tauM[t_] := tau0;

(* Differential equations *)
eqs = {
  q'[t] == qdot[t],
  qdot'[t] ==
    (k (th[t] - q[t]) +
     d (thdot[t] - qdot[t]) -
     m g ell Sin[q[t]] - b_l qdot[t]) / J_l,
  th'[t] == thdot[t],
  thdot'[t] ==
    (tauM[t] -
     k (th[t] - q[t]) -
     d (thdot[t] - qdot[t]) -
     b_m thdot[t]) / J_m
};

ics = {q[0] == 0, qdot[0] == 0, th[0] == 0, thdot[0] == 0};

sol = NDSolve[Join[eqs, ics], {q, qdot, th, thdot}, {t, 0, 2}][[1]];

Plot[{q[t] /. sol, th[t] /. sol}, {t, 0, 2},
  PlotLegends -> {"link q", "motor theta"},
  AxesLabel -> {"t [s]", "angle [rad]"},
  GridLines -> Automatic
]
      
