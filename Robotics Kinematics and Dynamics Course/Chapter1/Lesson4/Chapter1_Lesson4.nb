J = 0.01;
b = 0.1;
k = 1.0;

u[t_] := 1.0; (* constant torque *)

eq = J*q''[t] + b*q'[t] + k*q[t] == u[t];
ic = {q[0] == 0, q'[0] == 0};

sol = NDSolve[{eq, ic}, q, {t, 0, 5}];

Plot[Evaluate[q[t] /. sol], {t, 0, 5},
     AxesLabel -> {"t", "q(t)"},
     PlotLabel -> "Single-DOF joint response (Mathematica)"]
      
