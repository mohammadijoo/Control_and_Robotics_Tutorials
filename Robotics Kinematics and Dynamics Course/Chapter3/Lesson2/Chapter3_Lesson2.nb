skew[{wx_, wy_, wz_}] := {
    {0,   -wz,  wy},
    {wz,   0,  -wx},
    {-wy,  wx,  0}
};

axisAngleToR[axis_List, theta_] := Module[{w, K},
    w = axis/Norm[axis];
    K = skew[w];
    IdentityMatrix[3] + Sin[theta] K + (1 - Cos[theta]) K.K
];

RToAxisAngle[R_] := Module[{trace, cosTheta, theta, axis, eps = 10^-8},
    trace = Tr[R];
    cosTheta = (trace - 1)/2;
    cosTheta = Min[1, Max[-1, cosTheta]];
    theta = ArcCos[cosTheta];

    If[theta < eps,
        Return[{ {1, 0, 0}, 0.0 }]
    ];

    axis = (1/(2 Sin[theta])) * {
        R[[3, 2]] - R[[2, 3]],
        R[[1, 3]] - R[[3, 1]],
        R[[2, 1]] - R[[1, 2]]
    };
    axis = axis/Norm[axis];
    {axis, theta}
];
      
