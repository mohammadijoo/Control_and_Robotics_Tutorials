(* Time, generalized coordinate, and parameters *)
t   = Symbol["t"];
q[t_] := q[t];
m = Symbol["m"];
l = Symbol["l"];
g = Symbol["g"];

qdot[t_] := D[q[t], t];

(* Energies *)
T = 1/2 m l^2 qdot[t]^2;
V = m g l (1 - Cos[q[t]]);

L = T - V;

(* Euler-Lagrange equation *)
EL = D[D[L, qdot[t]], t] - D[L, q[t]];

(* Introduce external torque tau[t] *)
tau[t_] := Symbol["tau"][t];
eq = Simplify[EL - tau[t] == 0];

(* Solve for qddot *)
qddot = D[q[t], {t, 2}];
sol = Solve[eq, qddot][[1, 1, 2]] // Simplify
      
