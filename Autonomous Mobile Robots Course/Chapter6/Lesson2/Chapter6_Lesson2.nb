(* Chapter6_Lesson2.nb
   Bayes Filters for Mobile Robots (discrete-state version)
   This is a plain-text Wolfram Notebook expression. Open with Mathematica. *)

Notebook[{
  Cell["Chapter 6 — Lesson 2: Bayes Filters for Mobile Robots", "Title"],
  Cell["Discrete Bayes filter recursion on a finite state space.", "Text"],

  Cell[BoxData[
    RowBox[{
      RowBox[{"Normalize", "[", "p_", "]"}], ":=",
      RowBox[{"Module", "[",
        RowBox[{
          RowBox[{"{", RowBox[{"s", "=", RowBox[{"Total", "[", "p", "]"}]}], "}"}],
          ",",
          RowBox[{"If", "[",
            RowBox[{
              RowBox[{"s", "<", RowBox[{"10", "^", RowBox[{"-", "12"}]}]}],
              ",",
              RowBox[{"ConstantArray", "[", RowBox[{RowBox[{"1", "/", RowBox[{"Length", "[", "p", "]"}]}], ",", RowBox[{"Length", "[", "p", "]"}]}], "]"}],
              ",",
              RowBox[{"p", "/", "s"}]
            }],
          "]"}]
        }],
      "]"}]}]], "Input"],

  Cell[BoxData[
    RowBox[{
      RowBox[{"Predict", "[",
        RowBox[{"belPrev_", ",", "T_"}], "]"}], ":=",
      RowBox[{"Normalize", "[", RowBox[{"T", ".", "belPrev"}], "]"}]}]], "Input"],

  Cell[BoxData[
    RowBox[{
      RowBox[{"Update", "[",
        RowBox[{"belBar_", ",", "L_"}], "]"}], ":=",
      RowBox[{"Normalize", "[", RowBox[{"L", "*", "belBar"}], "]"}]}]], "Input"],

  Cell["1D ring corridor demo (N=20, two landmarks).", "Section"],

  Cell[BoxData[
    RowBox[{
      RowBox[{"MakeShiftTransition", "[",
        RowBox[{"N_", ",", "delta_", ",", "pExact_", ",", "pUnder_", ",", "pOver_"}],
      "]"}], ":=",
      RowBox[{"Module", "[",
        RowBox[{
          RowBox[{"{", RowBox[{"T", ",", "mod"}], "}"}],
          ",",
          RowBox[{
            RowBox[{"T", "=", RowBox[{"ConstantArray", "[", RowBox[{"0.0", ",", RowBox[{"{", RowBox[{"N", ",", "N"}], "}"}]}], "]"}]}], ";",
            RowBox[{"mod", "=", RowBox[{"Function", "[", RowBox[{"k", ",", RowBox[{"Mod", "[", RowBox[{"k", ",", "N"}], "]"}]}], "]"}]}], ";",
            RowBox[{"Do", "[",
              RowBox[{
                RowBox[{
                  RowBox[{"T", "[", RowBox[{"[", RowBox[{
                    RowBox[{"mod", "[", RowBox[{"j", "+", "delta"}], "]"}], "+", "1"
                  }], ",", RowBox[{"j", "+", "1"}]}], "]"}], "]"}], "+=", "pExact"}], ";",
                  RowBox[{"T", "[", RowBox[{"[", RowBox[{
                    RowBox[{"mod", "[", RowBox[{"j", "+", "delta", "-", "1"}], "]"}], "+", "1"
                  }], ",", RowBox[{"j", "+", "1"}]}], "]"}], "]"}], "+=", "pUnder"}], ";",
                  RowBox[{"T", "[", RowBox[{"[", RowBox[{
                    RowBox[{"mod", "[", RowBox[{"j", "+", "delta", "+", "1"}], "]"}], "+", "1"
                  }], ",", RowBox[{"j", "+", "1"}]}], "]"}], "]"}], "+=", "pOver"}], ";"
                }],
                RowBox[{"{", RowBox[{"j", ",", "0", ",", RowBox[{"N", "-", "1"}]}], "}"}]
              }],
            "]"}], ";",
            "T"
          }]
        }],
      "]"}]}]], "Input"],

  Cell[BoxData[
    RowBox[{
      RowBox[{"LandmarkLikelihood", "[",
        RowBox[{"N_", ",", "z_", ",", "landmarks_", ",", "pHit_", ",", "pFalse_"}],
      "]"}], ":=",
      RowBox[{"Module", "[",
        RowBox[{
          RowBox[{"{", RowBox[{"L", ",", "base"}], "}"}],
          ",",
          RowBox[{
            RowBox[{"base", "=", RowBox[{"If", "[", RowBox[{RowBox[{"z", "==", "1"}], ",", "pFalse", ",", RowBox[{"1.0", "-", "pFalse"}]}], "]"}]}], ";",
            RowBox[{"L", "=", RowBox[{"ConstantArray", "[", RowBox[{"base", ",", "N"}], "]"}]}], ";",
            RowBox[{"Do", "[",
              RowBox[{
                RowBox[{
                  RowBox[{"L", "[", RowBox[{"[", RowBox[{RowBox[{"Mod", "[", RowBox[{"lm", ",", "N"}], "]"}], "+", "1"}], "]"}], "]"}], "]"}],
                  "=",
                  RowBox[{"If", "[", RowBox[{RowBox[{"z", "==", "1"}], ",", "pHit", ",", RowBox[{"1.0", "-", "pHit"}]}], "]"}]}],
                RowBox[{"{", RowBox[{"lm", ",", "landmarks"}], "}"}]
              }],
            "]"}], ";",
            "L"
          }]
        }],
      "]"}]}]], "Input"],

  Cell[BoxData[
    RowBox[{
      RowBox[{"SeedRandom", "[", "4", "]"}], ";",
      RowBox[{"N", "=", "20"}], ";",
      RowBox[{"bel", "=", RowBox[{"ConstantArray", "[", RowBox[{RowBox[{"1.0", "/", "N"}], ",", "N"}], "]"}]}], ";",
      RowBox[{"landmarks", "=", RowBox[{"{", RowBox[{"3", ",", "14"}], "}"}]}], ";",
      RowBox[{"controls", "=", RowBox[{"{", RowBox[{"1", ",", "1", ",", "1", ",", "2", ",", "1", ",", "1", ",", "2", ",", "1"}], "}"}]}], ";",
      RowBox[{"x", "=", RowBox[{"RandomInteger", "[", RowBox[{"{", RowBox[{"0", ",", RowBox[{"N", "-", "1"}]}], "}"}], "]"}]}], ";",
      RowBox[{"truth", "=", RowBox[{"{", "x", "}"}]}], ";",
      RowBox[{"zs", "=", RowBox[{"{", "}"}]}], ";",
      "\n",
      RowBox[{"Do", "[",
        RowBox[{
          RowBox[{
            RowBox[{"u", "=", RowBox[{"controls", "[", RowBox[{"[", "t", "]"}], "]"}]}], ";",
            RowBox[{"r", "=", RowBox[{"RandomReal", "[", "]"}]}], ";",
            RowBox[{"x", "=",
              RowBox[{"If", "[",
                RowBox[{
                  RowBox[{"r", "<", "0.8"}],
                  ",", RowBox[{"Mod", "[", RowBox[{"x", "+", "u", ",", "N"}], "]"}],
                  ",",
                  RowBox[{"If", "[",
                    RowBox[{
                      RowBox[{"r", "<", "0.9"}],
                      ",", RowBox[{"Mod", "[", RowBox[{"x", "+", "u", "-", "1", ",", "N"}], "]"}],
                      ",", RowBox[{"Mod", "[", RowBox[{"x", "+", "u", "+", "1", ",", "N"}], "]"}]
                    }],
                  "]"}]
                }],
              "]"}]}], ";",
            RowBox[{"truth", "=", RowBox[{"Append", "[", RowBox[{"truth", ",", "x"}], "]"}]}], ";",
            RowBox[{"atLm", "=", RowBox[{"MemberQ", "[", RowBox[{"landmarks", ",", "x"}], "]"}]}], ";",
            RowBox[{"z", "=", RowBox[{"If", "[",
              RowBox[{"atLm",
                ",", RowBox[{"If", "[", RowBox[{RowBox[{"RandomReal", "[", "]"}], "<", "0.9"}], ",", "1", ",", "0"}], "]"}],
                ",", RowBox[{"If", "[", RowBox[{RowBox[{"RandomReal", "[", "]"}], "<", "0.1"}], ",", "1", ",", "0"}], "]"}]
              }],
            "]"}]}], ";",
            RowBox[{"zs", "=", RowBox[{"Append", "[", RowBox[{"zs", ",", "z"}], "]"}]}], ";"
          }],
          RowBox[{"{", RowBox[{"t", ",", "1", ",", RowBox[{"Length", "[", "controls", "]"}]}], "}"}]
        }],
      "]"}], ";",
      "\n",
      RowBox[{"Do", "[",
        RowBox[{
          RowBox[{
            RowBox[{"u", "=", RowBox[{"controls", "[", RowBox[{"[", "t", "]"}], "]"}]}], ";",
            RowBox[{"z", "=", RowBox[{"zs", "[", RowBox[{"[", "t", "]"}], "]"}]}], ";",
            RowBox[{"T", "=", RowBox[{"MakeShiftTransition", "[", RowBox[{"N", ",", "u", ",", "0.8", ",", "0.1", ",", "0.1"}], "]"}]}], ";",
            RowBox[{"L", "=", RowBox[{"LandmarkLikelihood", "[", RowBox[{"N", ",", "z", ",", "landmarks", ",", "0.9", ",", "0.1"}], "]"}]}], ";",
            RowBox[{"bel", "=", RowBox[{"Update", "[", RowBox[{RowBox[{"Predict", "[", RowBox[{"bel", ",", "T"}], "]"}], ",", "L"}], "]"}]}], ";"
          }],
          RowBox[{"{", RowBox[{"t", ",", "1", ",", RowBox[{"Length", "[", "controls", "]"}]}], "}"}]
        }],
      "]"}], ";",
      RowBox[{"Print", "[", "\"Final belief top-5 states:\"",
        "]"}], ";",
      RowBox[{"idx", "=", RowBox[{"Reverse", "[", RowBox[{"Ordering", "[", "bel", "]"}], "]"}]}], ";",
      RowBox[{"Do", "[",
        RowBox[{
          RowBox[{"Print", "[",
            RowBox[{"\"state \"", ",", RowBox[{"idx", "[", RowBox[{"[", "k", "]"}], "]"}], "-", "1", ",", "\" : \"", ",", RowBox[{"NumberForm", "[", RowBox[{RowBox[{"bel", "[", RowBox[{"[", RowBox[{"idx", "[", RowBox[{"[", "k", "]"}], "]"}], "]"}], "]"}], "]"}], ",", RowBox[{"{", RowBox[{"Infinity", ",", "4"}], "}"}]}], "]"}]}],
          "]"}],
          RowBox[{"{", RowBox[{"k", ",", "1", ",", "5"}], "}"}]
        }],
      "]"}], ";",
      RowBox[{"Print", "[", RowBox[{"\"Truth trajectory: \"", ",", "truth"}], "]"}], ";"
    }]], "Input"]
},
WindowSize -> {1000, 700},
StyleDefinitions -> "Default.nb"
]
