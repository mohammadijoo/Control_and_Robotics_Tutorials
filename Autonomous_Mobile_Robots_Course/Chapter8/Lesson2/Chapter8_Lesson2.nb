(* ::Package:: *)

(* Chapter 8 - Lesson 2: Importance Sampling and Resampling (Particle Filters)
   Wolfram Language / Mathematica notebook (as a plain-text .nb expression).
   Open in Mathematica; it will render as a notebook.
*)

Notebook[{
  Cell["Chapter 8 - Lesson 2: Importance Sampling and Resampling", "Title"],
  Cell["From-scratch utilities: log-sum-exp, ESS, and systematic resampling.", "Text"],

  Cell[BoxData@ToBoxes[
    logSumExp[logw_List] := Module[{m = Max[logw]},
      m + Log[Total[Exp[logw - m]]]
    ];
  ], "Input"],

  Cell[BoxData@ToBoxes[
    normalizeLogWeights[logw_List] := Module[{lse = logSumExp[logw], w},
      w = Exp[logw - lse];
      w/Total[w]
    ];
  ], "Input"],

  Cell[BoxData@ToBoxes[
    ess[w_List] := 1/Total[w^2];
  ], "Input"],

  Cell[BoxData@ToBoxes[
    systematicResample[w_List] := Module[{n = Length[w], cdf, u0, u, j = 1, a},
      cdf = Accumulate[w];
      u0 = RandomReal[]/n;
      a = ConstantArray[0, n];
      Do[
        u = u0 + (i - 1)/n;
        While[u > cdf[[j]] && j < n, j++];
        a[[i]] = j;
      , {i, 1, n}];
      a
    ];
  ], "Input"],

  Cell["Demo: 1D tracking-like update with adaptive resampling.", "Text"],

  Cell[BoxData@ToBoxes[
    Module[{n = 2000, q = 0.4, r = 0.7, u = 0.3, x, xTrue = 2.0, z, logw, w, neff, xHat, a},
      SeedRandom[7];
      x = 4.0 RandomVariate[NormalDistribution[0, 1], n];

      Do[
        xTrue = xTrue + u + q RandomVariate[NormalDistribution[0, 1]];
        x = x + u + q RandomVariate[NormalDistribution[0, 1], n];
        z = xTrue + r RandomVariate[NormalDistribution[0, 1]];

        logw = -0.5 ((z - x)/r)^2;
        w = normalizeLogWeights[logw];
        neff = ess[w];
        xHat = Total[w x];

        Print[
          "t=", IntegerString[t, 10, 2],
          ", z=", NumberForm[z, {Infinity, 3}],
          ", true=", NumberForm[xTrue, {Infinity, 3}],
          ", est=", NumberForm[xHat, {Infinity, 3}],
          ", ESS=", NumberForm[neff, {Infinity, 1}]
        ];

        If[neff < 0.5 n,
          a = systematicResample[w];
          x = x[[a]];
        ];
      , {t, 1, 8}];
    ]
  ], "Input"]
},
WindowTitle -> "Chapter8_Lesson2.nb"
]
