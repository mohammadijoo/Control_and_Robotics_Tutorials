(* Chapter2_Lesson1.nb
   Autonomous Mobile Robots (Control Engineering)
   Chapter 2, Lesson 1: Rolling Constraints and Instantaneous Motion

   This notebook (in plain-text Notebook[...] form) symbolically derives
   the lateral no-slip Pfaffian row for a standard wheel and verifies the ICR relation.
*)

Notebook[{
  Cell["Chapter 2, Lesson 1: Rolling Constraints and Instantaneous Motion", "Title"],

  Cell["1) Symbolic derivation of the lateral no-slip constraint", "Section"],
  Cell[BoxData[
    RowBox[{
      RowBox[{"Clear", "[", RowBox[{"vx", ",", "vy", ",", "w", ",", "lx", ",", "ly", ",", "a"}], "]"}], ";",
      "\n",
      RowBox[{"t", "=", RowBox[{"{", RowBox[{RowBox[{"Cos", "[", "a", "]"}], ",", RowBox[{"Sin", "[", "a", "]"}]}], "}"}]}], ";",
      "\n",
      RowBox[{"n", "=", RowBox[{"{", RowBox[{RowBox[{"-", RowBox[{"Sin", "[", "a", "]"}]}], ",", RowBox[{"Cos", "[", "a", "]"}]}], "}"}]}], ";",
      "\n",
      RowBox[{"r", "=", RowBox[{"{", RowBox[{"lx", ",", "ly"}], "}"}]}], ";",
      "\n",
      RowBox[{"v", "=", RowBox[{"{", RowBox[{"vx", ",", "vy"}], "}"}]}], ";",
      "\n",
      RowBox[{"kCrossR", "=", RowBox[{"{", RowBox[{RowBox[{"-", "ly"}], ",", "lx"}], "}"}]}], ";",
      "\n",
      RowBox[{"vpt", "=", RowBox[{"v", "+", RowBox[{"w", "*", "kCrossR"}]}]}], ";",
      "\n",
      RowBox[{"constraint", "=", RowBox[{"Simplify", "[", RowBox[{"n", ".", "vpt"}], "]"}]}], ";",
      "\n",
      RowBox[{"constraint", "//", "TraditionalForm"}]
    }]], "Input"],

  Cell["The constraint has the Pfaffian form a . {vx, vy, w} = 0.", "Text"],

  Cell["2) ICR relation check", "Section"],
  Cell[BoxData[
    RowBox[{
      RowBox[{"pICR", "=", RowBox[{"{", RowBox[{RowBox[{"-", RowBox[{"vy", "/", "w"}]}], ",", RowBox[{"vx", "/", "w"}]}], "}"}]}], ";",
      "\n",
      RowBox[{"vFromICR", "=", RowBox[{"w", "*", RowBox[{"{", RowBox[{RowBox[{"-", RowBox[{"pICR", "[", RowBox[{"[", "2", "]"}], "]"}]}], ",", RowBox[{"pICR", "[", RowBox[{"[", "1", "]"}], "]"}]}], "}"}]}]}], ";",
      "\n",
      RowBox[{"Simplify", "[", RowBox[{"vFromICR", "-", RowBox[{"{", RowBox[{"vx", ",", "vy"}], "}"}]}], "]"}]
    }]], "Input"],

  Cell["If w != 0, vFromICR equals {vx, vy}, confirming v = w k x pICR.", "Text"]
},
WindowSize->{1000, 700},
StyleDefinitions->"Default.nb"
]
