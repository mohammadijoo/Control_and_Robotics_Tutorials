(* Parameters *)
m = 1.0;
b = 0.4;
k = 4.0;

(* ODE: m y''[t] + b y'[t] + k y[t] == 1 for t >= 0, with zero ICs *)
ode = m*y''[t] + b*y'[t] + k*y[t] == 1;

ics = {y[0] == 0, y'[0] == 0};

sol = NDSolve[{ode, ics}, y, {t, 0, 10}];

Plot[Evaluate[y[t] /. sol], {t, 0, 10},
     AxesLabel -> {"t", "y(t)"},
     PlotLabel -> "Mass-spring-damper response in Mathematica"]
