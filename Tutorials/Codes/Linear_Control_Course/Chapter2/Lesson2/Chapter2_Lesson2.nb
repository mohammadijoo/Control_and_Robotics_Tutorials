(* Parameters *)
A = 1.0;
phiU = 30 Degree;
omega = 10.0;
tau = 0.05;

U = A Exp[I phiU];
H[om_] := 1/(1 + I tau om);
Y = H[omega] U // FullSimplify;

(* Magnitude and phase *)
magH = Abs[H[omega]];
phaseH = Arg[H[omega]];

Print["H(j omega) magnitude = ", magH];
Print["H(j omega) phase [deg] = ", N[phaseH * 180 / Pi]];

(* Time-domain expression for y(t) *)
y[t_] := Re[Y Exp[I omega t]] // FullSimplify
