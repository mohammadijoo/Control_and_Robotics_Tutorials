(* Parameters *)
K   = 2.0;
tau = 0.5;

(* First-order transfer function G(s) = K / (tau s + 1) *)
G = TransferFunctionModel[K/(tau*s + 1), s];

(* Display transfer function *)
G // Simplify

(* Unit-step response over [0, 5] seconds *)
StepResponsePlot[G, {t, 0, 5},
  Frame -> True,
  FrameLabel -> {"t [s]", "y(t)"},
  PlotLegends -> {"Step response"}
]
