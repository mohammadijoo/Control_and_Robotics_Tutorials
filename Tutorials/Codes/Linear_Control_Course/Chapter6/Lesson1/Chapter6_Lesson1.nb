wn   = 4.0;
zeta = 0.7;
K    = 1.0;

s = LaplaceTransformVariable["s"];

G = TransferFunctionModel[
      K*wn^2/(s^2 + 2*zeta*wn*s + wn^2),
      s
    ];

y[t_] = OutputResponse[G, UnitStep[t], {t, 0, 5}];

Plot[y[t], {t, 0, 5},
     AxesLabel -> {"t", "y(t)"},
     PlotLabel -> "Standard second-order step response (Mathematica)"]
