a = 1.0;
b = 2.0;
K = 3.0;
r0 = 1.0;

eq = y'[t] == -(a + b*K)*y[t] + b*K*r0;
ic = y[0] == 0.0;

sol = NDSolve[{eq, ic}, y, {t, 0, 2.0}];

Plot[{Evaluate[y[t] /. sol], r0}, {t, 0, 2.0},
     PlotLegends -> {"y(t)", "reference"},
     AxesLabel -> {"t", "output"},
     PlotLabel -> "First-order closed-loop response"];
