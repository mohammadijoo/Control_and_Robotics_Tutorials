J = 0.01;
B = 0.1;
K = 1.0;
Kp = 5.0;

s = ComplexExpand[I*w] /. w ->. w; (* symbolic placeholder *)

G = TransferFunctionModel[K/(J*s^2 + B*s), s];
C = Kp;
L = C*G;

NyquistPlot[L, {w, 0.01, 1000},
  AxesLabel -> {"Re", "Im"},
  PlotRange -> All,
  GridLines -> Automatic,
  PlotLegends -> {"Loop Transfer Function"}
]
