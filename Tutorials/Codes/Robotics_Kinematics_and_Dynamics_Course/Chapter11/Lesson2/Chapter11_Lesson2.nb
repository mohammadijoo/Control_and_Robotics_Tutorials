(* General symbolic setup *)
ClearAll["Global`*"];
n   = 2;
q   = Array[q, n];
dq  = Array[dq, n];
{a1, a2, a3} = Array[a, 3];

M = { {a1 + 2 a2 Cos[q[[2]]], a3 + a2 Cos[q[[2]]]},
     {a3 + a2 Cos[q[[2]]],   a3} };

(* Christoffel symbols of the second kind *)
c[i_, j_, k_] :=
  1/2 (D[M[[i, j]], q[[k]]] +
       D[M[[i, k]], q[[j]]] -
       D[M[[j, k]], q[[i]]]);

C = Array[
      Function[{i, j},
        Sum[c[i, j, k] dq[[k]], {k, 1, n}]
      ],
      {n, n}
    ] // Simplify;

MatrixForm[M]
MatrixForm[C]
      
