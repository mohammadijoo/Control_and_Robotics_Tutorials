(* Scalar saturation *)
sat[u_, umin_, umax_] :=
  Piecewise[{
    {umax, u >= umax},
    {u, umin <= u <= umax},
    {umin, u <= umin}
  }];

(* 1-DOF dynamics parameters *)
Clear[I, b, q, qd, gq, tau, tauMin, tauMax];
gq = Symbol["g"][q];

(* Acceleration in terms of torque *)
ddq[tau_] := (tau - b*qd - gq)/I;

(* Symbolic acceleration bounds *)
ddqMin = Simplify[ddq[tauMin]];
ddqMax = Simplify[ddq[tauMax]];

{ddqMin, ddqMax}
      
