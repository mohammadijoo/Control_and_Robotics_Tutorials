(* Define symbolic variables *)
Clear[q1, q2, l1, l2, fx, fy];
Jp = {
  {-l1*Sin[q1] - l2*Sin[q1 + q2], -l2*Sin[q1 + q2]},
  { l1*Cos[q1] + l2*Cos[q1 + q2],  l2*Cos[q1 + q2]}
};

f = {fx, fy};
tau = Transpose[Jp].f // Simplify

(* Substitute numerical values *)
tauNum = tau /. {
   q1 -> Pi/4, q2 -> Pi/6,
   l1 -> 1.0, l2 -> 0.8,
   fx -> 10.0, fy -> 0.0
} // N
      
