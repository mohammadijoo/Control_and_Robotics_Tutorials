Clear[hat, transformWrench];

hat[p_List] /; Length[p] == 3 := { {0, -p[[3]], p[[2]]},
                                  {p[[3]], 0, -p[[1]]},
                                  {-p[[2]], p[[1]], 0} };

transformWrench[R_?MatrixQ, p_List, wB_List] := Module[
  {fB, mB, fA, mA},
  fB = Take[wB, 3];
  mB = Take[wB, -3];
  fA = R . fB;
  mA = hat[p] . fA + R . mB;
  Join[fA, mA]
];

(* Example usage *)
R = { {0, 0, 1},
     {0, 1, 0},
     {-1, 0, 0} };
p = {0.5, 0, 0};
wB = {0, 0, 10, 0, 0, 0};

wA = transformWrench[R, p, wB] // Simplify
      
