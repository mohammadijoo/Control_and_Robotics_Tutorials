
m   = 1.0;
b   = 1.0;
kP  = 200.0;
kD  = 20.0;
kE  = 5000.0;
xS  = 0.0;
fMax = 80.0;

xDes[t_] := Piecewise[{ {-0.02, t < 0.1}, {0.03, t >= 0.1} }];

dt = 0.0005;
tEnd = 1.0;
steps = Round[tEnd/dt];

x  = -0.02;
v  = 0.0;

data = Reap[
  Do[
    t = n*dt;
    fE = If[x <= xS, 0.0, kE (x - xS)];
    e  = xDes[t] - x;
    u  = kP e - kD v;
    If[fE > fMax, u = u - (fE - fMax)];
    a  = (u - fE - b v)/m;
    v  = v + dt a;
    x  = x + dt v;
    Sow[{t, x, fE}],
    {n, 0, steps}
  ]
][[2, 1]];

ListLinePlot[
  {data[[All, {1, 2}]], data[[All, {1, 3}]]},
  PlotLegends -> {"x(t)", "F_e(t)"},
  GridLines -> Automatic
]
