
(* Parameters *)
M_a = 3.0;
D_a = 20.0;
K_a = 50.0;
x0 = 0.0;

(* State variables x_r and xdot_r *)
xr[t_] := x[t];
xrdot[t_] := x'[t];

Fext[t_] := 10.0 * UnitStep[t - 0.2];

eq = M_a*x''[t] + D_a*x'[t] + K_a*(x[t] - x0) == Fext[t];

ic = {x[0] == x0, x'[0] == 0.0};

sol = NDSolve[{eq, ic}, x, {t, 0, 2.0}];

xrPlot = Plot[Evaluate[x[t] /. sol], {t, 0, 2.0},
  AxesLabel -> {"t", "x_r"},
  PlotLabel -> "Admittance response"];

xrPlot
