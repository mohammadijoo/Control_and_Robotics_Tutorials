
(* Example: scalar error e(t) = Exp[-a t] *)
Clear[a, t];
e[t_] := Exp[-a t];

JISE[a_?Positive, tFinal_?Positive] :=
  Integrate[e[t]^2, {t, 0, tFinal}]

(* L2 norm over [0, Infinity) provided a > 0 *)
L2Norm[a_?Positive] :=
  Sqrt[Integrate[e[t]^2, {t, 0, Infinity}]]

(* Numerical evaluation for a = 1, tFinal = 10 *)
JISE[1, 10] // N
L2Norm[1] // N
