
J = 0.05;
b = 0.01;
kp = 50.;
kd = 2.;
Ts = 0.001;

A = { {1., Ts}, {-Ts*kp/J, 1. - Ts*(kd + b)/J} };

(* initial error state: e_q, e_dq *)
x0 = {0.1, 0.0};
nSteps = Round[5./Ts];

x[0] = x0;
x[k_Integer?Positive] := x[k] = A.x[k - 1];

traj = Table[x[k], {k, 0, nSteps}];
tvec = Range[0, nSteps]*Ts;

eQ = traj[[All, 1]];
eDq = traj[[All, 2]];
V = eQ^2 + eDq^2;

ListLinePlot[
  {
    Transpose[{tvec, eQ}],
    Transpose[{tvec, eDq}],
    Transpose[{tvec, V}]
  },
  PlotLegends -> {"e_q", "e_dq", "V"},
  AxesLabel -> {"t (s)", "value"}
]
