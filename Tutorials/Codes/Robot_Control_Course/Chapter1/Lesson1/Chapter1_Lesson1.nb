
Kp  = 5.0;
tau = 0.2;

(* Continuous-time closed-loop transfer for unity feedback *)
G[s_]  := 1/(1 + tau*s);
Tcl[s_] := (Kp*G[s])/(1 + Kp*G[s]);

sys = TransferFunctionModel[Tcl[s], s];

(* Step response *)
ResponsePlot[
  {SystemResponse[sys, UnitStep], 1},
  {t, 0, 1},
  PlotLegends -> {"output", "reference"},
  Frame -> True,
  FrameLabel -> {"time (s)", "joint position"}
]
