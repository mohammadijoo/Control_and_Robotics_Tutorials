
kP = 2.0;
gamma = 5.0;
xRef = -1.0;

uNom[x_] := -kP (x - xRef);
uSafe[x_] := Max[uNom[x], -gamma x];

tmax = 2.0;
x0 = 0.05;

sol = NDSolve[{
    x'[t] == uSafe[x[t]],
    x[0] == x0
    },
   {x}, {t, 0, tmax}
];

Plot[Evaluate[{x[t]} /. sol], {t, 0, tmax},
  AxesLabel -> {"t", "x(t)"},
  PlotLegends -> {"x(t)"},
  Epilog -> {Dashed, Line[{ {0, 0}, {tmax, 0} }]}
]
