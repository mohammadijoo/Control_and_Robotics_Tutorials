(* Chapter8_Lesson4.nb
   Particle-Filter Localization — Degeneracy + Kidnapped Robot Recovery (2D)

   Open this file in Wolfram Mathematica.
   It creates a compact MCL simulation and writes "Chapter8_Lesson4_results.csv".
*)

Notebook[{
  Cell["Chapter 8 — Particle-Filter Localization", "Title"],
  Cell["Lesson 4: Degeneracy, Kidnapped Robot Problem", "Subtitle"],

  Cell["1. Utilities", "Section"],
  Cell[BoxData[RowBox[{"ClearAll", "[", "\"Global`*\"", "]"}]], "Input"],

  Cell[BoxData[
    RowBox[{
      RowBox[{"wrap", "[", "a_", "]"}], ":=",
      RowBox[{
        RowBox[{"Mod", "[", RowBox[{"a", "+", "Pi", ",", RowBox[{"2", "Pi"}]}], "]"}], "-", "Pi"}]}]], "Input"],

  Cell[BoxData[
    RowBox[{
      RowBox[{"logGauss0", "[", RowBox[{"e_", ",", "s_"}], "]"}], ":=",
      RowBox[{
        RowBox[{"-", "1/2"}], "*", RowBox[{"(", RowBox[{"e", "/", "s"}], ")"}], "^", "2",
        "-", RowBox[{"Log", "[", RowBox[{"Sqrt", "[", RowBox[{"2", "Pi"}], "]"}], " ", "s"}], "]"}]}]], "Input"],

  Cell["2. Motion + Measurement Models", "Section"],

  Cell[BoxData[
    RowBox[{
      RowBox[{"motionStep", "[",
        RowBox[{"x_", ",", "v_", ",", "w_", ",", "dt_", ",", "sv_", ",", "sw_"}], "]"}],
      ":=",
      RowBox[{"Module", "[",
        RowBox[{
          RowBox[{"{", RowBox[{"vn", ",", "wn", ",", "x2", ",", "y2", ",", "th2"}], "}"}], ",",
          RowBox[{
            RowBox[{"vn", "=", RowBox[{"v", "+", RowBox[{"sv", " ", RowBox[{"RandomVariate", "[", RowBox[{"NormalDistribution", "[", RowBox[{"0", ",", "1"}], "]"}], "]"}]}]}]}], ";",
            RowBox[{"wn", "=", RowBox[{"w", "+", RowBox[{"sw", " ", RowBox[{"RandomVariate", "[", RowBox[{"NormalDistribution", "[", RowBox[{"0", ",", "1"}], "]"}], "]"}]}]}]}], ";",
            RowBox[{"If", "[",
              RowBox[{
                RowBox[{"Abs", "[", "wn", "]"}], "<", "10^-9", ",",
                RowBox[{
                  RowBox[{"x2", "=", RowBox[{"x", "[", RowBox[{"[", "1", "]"}], "]"}], "+", RowBox[{"vn", " ", "dt", " ", RowBox[{"Cos", "[", RowBox[{"x", "[", RowBox[{"[", "3", "]"}], "]"}], "]"}]}]}], ";",
                  RowBox[{"y2", "=", RowBox[{"x", "[", RowBox[{"[", "2", "]"}], "]"}], "+", RowBox[{"vn", " ", "dt", " ", RowBox[{"Sin", "[", RowBox[{"x", "[", RowBox[{"[", "3", "]"}], "]"}], "]"}]}]}], ";",
                  RowBox[{"th2", "=", RowBox[{"x", "[", RowBox[{"[", "3", "]"}], "]"}]}], ";"
                }], ",",
                RowBox[{
                  RowBox[{"x2", "=", RowBox[{"x", "[", RowBox[{"[", "1", "]"}], "]"}], "+",
                    RowBox[{"(", RowBox[{"vn", "/", "wn"}], ")"}], "*",
                    RowBox[{"(", RowBox[{"Sin", "[", RowBox[{"x", "[", RowBox[{"[", "3", "]"}], "]"}], "+", "wn", " ", "dt"}], "]"}], "-", RowBox[{"Sin", "[", RowBox[{"x", "[", RowBox[{"[", "3", "]"}], "]"}], "]"}], ")"}]}], ";",
                  RowBox[{"y2", "=", RowBox[{"x", "[", RowBox[{"[", "2", "]"}], "]"}], "-",
                    RowBox[{"(", RowBox[{"vn", "/", "wn"}], ")"}], "*",
                    RowBox[{"(", RowBox[{"Cos", "[", RowBox[{"x", "[", RowBox[{"[", "3", "]"}], "]"}], "+", "wn", " ", "dt"}], "]"}], "-", RowBox[{"Cos", "[", RowBox[{"x", "[", RowBox[{"[", "3", "]"}], "]"}], "]"}], ")"}]}], ";",
                  RowBox[{"th2", "=", RowBox[{"x", "[", RowBox[{"[", "3", "]"}], "]"}], "+", "wn", " ", "dt"}], ";"
                }]
              }], "]"}], ";",
            RowBox[{"{", RowBox[{"x2", ",", "y2", ",", RowBox[{"wrap", "[", "th2", "]"}]}], "}"}]
          }]
        }], "]"}]}]], "Input"],

  Cell[BoxData[
    RowBox[{
      RowBox[{"measModel", "[", RowBox[{"x_", ",", "L_"}], "]"}], ":=",
      RowBox[{"Module", "[", RowBox[{"{", RowBox[{"dx", ",", "dy", ",", "r", ",", "b"}], "}"}], ",",
        RowBox[{
          RowBox[{"dx", "=", RowBox[{"L", "[", RowBox[{"[", RowBox[{"All", ",", "1"}], "]"}], "]"}], "-", RowBox[{"x", "[", RowBox[{"[", "1", "]"}], "]"}]}], ";",
          RowBox[{"dy", "=", RowBox[{"L", "[", RowBox[{"[", RowBox[{"All", ",", "2"}], "]"}], "]"}], "-", RowBox[{"x", "[", RowBox[{"[", "2", "]"}], "]"}]}], ";",
          RowBox[{"r", "=", RowBox[{"Sqrt", "[", RowBox[{"dx", "^", "2", "+", "dy", "^", "2"}], "]"}]}], ";",
          RowBox[{"b", "=", RowBox[{"wrap", "[", RowBox[{"ArcTan", "[", RowBox[{"dx", ",", "dy"}], "]"}], "-", RowBox[{"x", "[", RowBox[{"[", "3", "]"}], "]"}]}], "]"}], ";",
          RowBox[{"Transpose", "[", RowBox[{"{", RowBox[{"r", ",", "b"}], "}"}], "]"}]
        }]
      ], "]"}]}]], "Input"],

  Cell[BoxData[
    RowBox[{
      RowBox[{"logLike", "[", RowBox[{"x_", ",", "z_", ",", "L_", ",", "sr_", ",", "sb_"}], "]"}], ":=",
      RowBox[{"Module", "[", RowBox[{"{", RowBox[{"zh", ",", "dr", ",", "db"}], "}"}], ",",
        RowBox[{
          RowBox[{"zh", "=", RowBox[{"measModel", "[", RowBox[{"x", ",", "L"}], "]"}]}], ";",
          RowBox[{"dr", "=", RowBox[{"z", "[", RowBox[{"[", RowBox[{"All", ",", "1"}], "]"}], "]"}], "-", RowBox[{"zh", "[", RowBox[{"[", RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";",
          RowBox[{"db", "=", RowBox[{"wrap", "[", RowBox[{"z", "[", RowBox[{"[", RowBox[{"All", ",", "2"}], "]"}], "]"}], "-", RowBox[{"zh", "[", RowBox[{"[", RowBox[{"All", ",", "2"}], "]"}], "]"}]}], "]"}], ";",
          RowBox[{"Total", "[", RowBox[{"logGauss0", "[", RowBox[{"dr", ",", "sr"}], "]"}], "]"}], "+",
          RowBox[{"Total", "[", RowBox[{"logGauss0", "[", RowBox[{"db", ",", "sb"}], "]"}], "]"}]
        }]
      ], "]"}]}]], "Input"],

  Cell["3. Resampling + Diagnostics", "Section"],

  Cell[BoxData[
    RowBox[{
      RowBox[{"neff", "[", "w_", "]"}], ":=",
      RowBox[{"1", "/", RowBox[{"Total", "[", RowBox[{"w", "^", "2"}], "]"}]}]}]], "Input"],

  Cell[BoxData[
    RowBox[{
      RowBox[{"systematicResample", "[", "w_", "]"}], ":=",
      RowBox[{"Module", "[",
        RowBox[{
          RowBox[{"{", RowBox[{"N", ",", "cdf", ",", "u0", ",", "idx", ",", "i", ",", "u"}], "}"}], ",",
          RowBox[{
            RowBox[{"N", "=", RowBox[{"Length", "[", "w", "]"}]}], ";",
            RowBox[{"cdf", "=", RowBox[{"Accumulate", "[", "w", "]"}]}], ";",
            RowBox[{"cdf", "[", RowBox[{"[", RowBox[{"-", "1"}], "]"}], "]"}], "=", "1.0;",

            RowBox[{"u0", "=", RowBox[{"RandomReal", "[", "]"}], "/", "N"}], ";",
            RowBox[{"idx", "=", RowBox[{"ConstantArray", "[", RowBox[{"1", ",", "N"}], "]"}]}], ";",
            RowBox[{"i", "=", "1"}], ";",
            RowBox[{"Do", "[",
              RowBox[{
                RowBox[{
                  RowBox[{"u", "=", RowBox[{"u0", "+", RowBox[{"(", RowBox[{"m", "-", "1"}], ")"}], "/", "N"}]}], ";",
                  RowBox[{"While", "[", RowBox[{"u", ">", RowBox[{"cdf", "[", RowBox[{"[", "i", "]"}], "]"}]}], ",", RowBox[{"i", "++"}]}], "]"}], ";",
                  RowBox[{"idx", "[", RowBox[{"[", "m", "]"}], "]"}], "=", "i", ";"
                }],
                RowBox[{"{", RowBox[{"m", ",", "1", ",", "N"}], "}"}]
              }], "]"}], ";",
            "idx"
          }]
        }], "]"}]}]], "Input"],

  Cell["4. Main Simulation", "Section"],

  Cell[BoxData[
    RowBox[{
      RowBox[{"SeedRandom", "[", "4", "]"}], ";",
      RowBox[{"xmin", "=", "0.0"}], ";", RowBox[{"xmax", "=", "10.0"}], ";",
      RowBox[{"ymin", "=", "0.0"}], ";", RowBox[{"ymax", "=", "10.0"}], ";",
      RowBox[{"L", "=", RowBox[{"{", RowBox[{"{", RowBox[{"2.0", ",", "2.0"}], "}"}], ",",
                                  RowBox[{"{", RowBox[{"8.0", ",", "2.0"}], "}"}], ",",
                                  RowBox[{"{", RowBox[{"8.0", ",", "8.0"}], "}"}], ",",
                                  RowBox[{"{", RowBox[{"2.0", ",", "8.0"}], "}"}]}], "}"}]}], ";",
      RowBox[{"dt", "=", "0.1"}], ";",
      RowBox[{"T", "=", "300"}], ";",
      RowBox[{"kid", "=", "170"}], ";",
      RowBox[{"sv", "=", "0.05"}], ";", RowBox[{"sw", "=", "0.03"}], ";",
      RowBox[{"sr", "=", "0.15"}], ";", RowBox[{"sb", "=", "0.07"}], ";",
      RowBox[{"N", "=", "800"}], ";",
      RowBox[{"rho", "=", "0.5"}], ";",
      RowBox[{"epsMin", "=", "0.01"}], ";",
      RowBox[{"epsMax", "=", "0.30"}], ";",
      RowBox[{"llThresh", "=", RowBox[{"-", "12.0"}]}], ";",
      RowBox[{"xTrue", "=", RowBox[{"{", RowBox[{"1.0", ",", "1.0", ",", "0.0"}], "}"}]}], ";",
      RowBox[{"P", "=", RowBox[{"Transpose", "[", RowBox[{"{",
        RowBox[{
          RowBox[{"RandomReal", "[", RowBox[{"{", RowBox[{"xmin", ",", "xmax"}], "}"}], ",", "N"}], "]"}], ",",
          RowBox[{"RandomReal", "[", RowBox[{"{", RowBox[{"ymin", ",", "ymax"}], "}"}], ",", "N"}], "]"}], ",",
          RowBox[{"RandomReal", "[", RowBox[{"{", RowBox[{"-", "Pi", ",", "Pi"}], "}"}], ",", "N"}], "]"}]
        }], "}"}], "]"}]}], ";",
      RowBox[{"w", "=", RowBox[{"ConstantArray", "[", RowBox[{"1.0", "/", "N", ",", "N"}], "]"}]}], ";",
      RowBox[{"hist", "=", RowBox[{"{", "}"}]}], ";"
    }]], "Input"],

  Cell[BoxData[
    RowBox[{
      RowBox[{"control", "[", "t_", "]"}], ":=",
      RowBox[{"Which", "[",
        RowBox[{
          RowBox[{"t", "<", "70"}], ",", RowBox[{"{", RowBox[{"0.7", ",", "0.0"}], "}"}], ",",
          RowBox[{"t", "<", "90"}], ",", RowBox[{"{", RowBox[{"0.7", ",", "0.9"}], "}"}], ",",
          RowBox[{"t", "<", "160"}], ",", RowBox[{"{", RowBox[{"0.7", ",", "0.0"}], "}"}], ",",
          RowBox[{"t", "<", "180"}], ",", RowBox[{"{", RowBox[{"0.7", ",", "0.9"}], "}"}], ",",
          RowBox[{"t", "<", "250"}], ",", RowBox[{"{", RowBox[{"0.7", ",", "0.0"}], "}"}], ",",
          "True", ",", RowBox[{"{", RowBox[{"0.7", ",", "0.9"}], "}"}]
        }], "]"}]}]], "Input"],

  Cell[BoxData[
    RowBox[{
      RowBox[{"Do", "[",
        RowBox[{
          RowBox[{"Module", "[",
            RowBox[{"{", RowBox[{"u", ",", "v", ",", "om", ",", "z", ",", "ll", ",", "llm", ",", "lbar", ",", "eps", ",", "Ne"}], "}"}], ",",
            RowBox[{
              RowBox[{"u", "=", RowBox[{"control", "[", "t", "]"}]}], ";",
              RowBox[{"v", "=", RowBox[{"u", "[", RowBox[{"[", "1", "]"}], "]"}]}], ";",
              RowBox[{"om", "=", RowBox[{"u", "[", RowBox[{"[", "2", "]"}], "]"}]}], ";",

              RowBox[{"xTrue", "=", RowBox[{"motionStep", "[", RowBox[{"xTrue", ",", "v", ",", "om", ",", "dt", ",", "sv", ",", "sw"}], "]"}]}], ";",
              RowBox[{"If", "[", RowBox[{"t", "==", "kid", ",",
                RowBox[{"xTrue", "=", RowBox[{"{",
                  RowBox[{
                    RowBox[{"RandomReal", "[", RowBox[{"{", RowBox[{"xmin", ",", "xmax"}], "}"}], "]"}], ",",
                    RowBox[{"RandomReal", "[", RowBox[{"{", RowBox[{"ymin", ",", "ymax"}], "}"}], "]"}], ",",
                    RowBox[{"RandomReal", "[", RowBox[{"{", RowBox[{"-", "Pi", ",", "Pi"}], "}"}], "]"}]
                  }], "}"}]}]}], "]"}], ";",

              RowBox[{"z", "=", RowBox[{"measModel", "[", RowBox[{"xTrue", ",", "L"}], "]"}]}], ";",
              RowBox[{"z", "=", RowBox[{"z", "+", RowBox[{"Transpose", "[", RowBox[{"{",
                RowBox[{
                  RowBox[{"RandomVariate", "[", RowBox[{"NormalDistribution", "[", RowBox[{"0", ",", "sr"}], "]"}], ",", RowBox[{"Length", "[", "L", "]"}]}], "]"}], ",",
                  RowBox[{"RandomVariate", "[", RowBox[{"NormalDistribution", "[", RowBox[{"0", ",", "sb"}], "]"}], ",", RowBox[{"Length", "[", "L", "]"}]}], "]"}]
                }], "}"}], "]"}]}]}], ";",
              RowBox[{"z", "[", RowBox[{"[", RowBox[{"All", ",", "2"}], "]"}], "]"}], "=", RowBox[{"wrap", "[", RowBox[{"z", "[", RowBox[{"[", RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}], ";",

              RowBox[{"P", "=", RowBox[{"Map", "[",
                RowBox[{
                  RowBox[{
                    RowBox[{"motionStep", "[", RowBox[{"#", ",", "v", ",", "om", ",", "dt", ",", "sv", ",", "sw"}], "]"}], "&"}], ",", "P"}], "]"}]}], ";",

              RowBox[{"ll", "=", RowBox[{"Map", "[", RowBox[{
                RowBox[{
                  RowBox[{"logLike", "[", RowBox[{"#", ",", "z", ",", "L", ",", "sr", ",", "sb"}], "]"}], "&"}], ",", "P"}], "]"}]}], ";",
              RowBox[{"llm", "=", RowBox[{"Max", "[", "ll", "]"}]}], ";",
              RowBox[{"w", "=", RowBox[{"Exp", "[", RowBox[{"ll", "-", "llm"}], "]"}]}], ";",
              RowBox[{"w", "=", RowBox[{"w", "/", RowBox[{"Total", "[", "w", "]"}]}]}], ";",

              RowBox[{"lbar", "=", RowBox[{"Total", "[", RowBox[{"w", "*", "ll"}], "]"}]}], ";",
              RowBox[{"eps", "=", RowBox[{"If", "[", RowBox[{"lbar", "<", "llThresh", ",", "epsMax", ",", "epsMin"}], "]"}]}], ";",

              RowBox[{"Ne", "=", RowBox[{"neff", "[", "w", "]"}]}], ";",

              RowBox[{"If", "[", RowBox[{"Ne", "<", RowBox[{"rho", "*", "N"}], ",",
                RowBox[{"Module", "[", RowBox[{"{", RowBox[{"idx", ",", "m"}], "}"}], ",",
                  RowBox[{
                    RowBox[{"idx", "=", RowBox[{"systematicResample", "[", "w", "]"}]}], ";",
                    RowBox[{"P", "=", RowBox[{"P", "[", RowBox[{"[", "idx", "]"}], "]"}]}], ";",
                    RowBox[{"w", "=", RowBox[{"ConstantArray", "[", RowBox[{"1.0", "/", "N", ",", "N"}], "]"}]}], ";",

                    RowBox[{"m", "=", RowBox[{"Round", "[", RowBox[{"eps", "*", "N"}], "]"}]}], ";",
                    RowBox[{"If", "[", RowBox[{"m", ">", "0", ",",
                      RowBox[{
                        RowBox[{"P", "[", RowBox[{"[", RowBox[{"1", ";;", "m"}], "]"}], "]"}], "=",
                          RowBox[{"Transpose", "[", RowBox[{"{",
                            RowBox[{
                              RowBox[{"RandomReal", "[", RowBox[{"{", RowBox[{"xmin", ",", "xmax"}], "}"}], ",", "m"}], "]"}], ",",
                              RowBox[{"RandomReal", "[", RowBox[{"{", RowBox[{"ymin", ",", "ymax"}], "}"}], ",", "m"}], "]"}], ",",
                              RowBox[{"RandomReal", "[", RowBox[{"{", RowBox[{"-", "Pi", ",", "Pi"}], "}"}], ",", "m"}], "]"}]
                            }], "}"}], "]"}]}], ";"
                      }]}], "]"}], ";",

                    RowBox[{"ll", "=", RowBox[{"Map", "[", RowBox[{
                      RowBox[{
                        RowBox[{"logLike", "[", RowBox[{"#", ",", "z", ",", "L", ",", "sr", ",", "sb"}], "]"}], "&"}], ",", "P"}], "]"}]}], ";",
                    RowBox[{"llm", "=", RowBox[{"Max", "[", "ll", "]"}]}], ";",
                    RowBox[{"w", "=", RowBox[{"Exp", "[", RowBox[{"ll", "-", "llm"}], "]"}]}], ";",
                    RowBox[{"w", "=", RowBox[{"w", "/", RowBox[{"Total", "[", "w", "]"}]}]}], ";"
                  }]
                ], "]"}]
              }], "]"}], ";",

              RowBox[{"(* estimate *)"}], 
              RowBox[{"Module", "[", RowBox[{"{", RowBox[{"xhat", ",", "yhat", ",", "chat", ",", "shat", ",", "that"}], "}"}], ",",
                RowBox[{
                  RowBox[{"xhat", "=", RowBox[{"Total", "[", RowBox[{"w", "*", RowBox[{"P", "[", RowBox[{"[", RowBox[{"All", ",", "1"}], "]"}], "]"}]}], "]"}]}], ";",
                  RowBox[{"yhat", "=", RowBox[{"Total", "[", RowBox[{"w", "*", RowBox[{"P", "[", RowBox[{"[", RowBox[{"All", ",", "2"}], "]"}], "]"}]}], "]"}]}], ";",
                  RowBox[{"chat", "=", RowBox[{"Total", "[", RowBox[{"w", "*", RowBox[{"Cos", "[", RowBox[{"P", "[", RowBox[{"[", RowBox[{"All", ",", "3"}], "]"}], "]"}], "]"}]}], "]"}]}], ";",
                  RowBox[{"shat", "=", RowBox[{"Total", "[", RowBox[{"w", "*", RowBox[{"Sin", "[", RowBox[{"P", "[", RowBox[{"[", RowBox[{"All", ",", "3"}], "]"}], "]"}], "]"}]}], "]"}]}], ";",
                  RowBox[{"that", "=", RowBox[{"ArcTan", "[", RowBox[{"chat", ",", "shat"}], "]"}]}], ";",
                  RowBox[{"hist", "=", RowBox[{"Append", "[", RowBox[{"hist", ",",
                    RowBox[{"{", RowBox[{"t", ",", RowBox[{"xTrue", "[", RowBox[{"[", "1", "]"}], "]"}], ",", RowBox[{"xTrue", "[", RowBox[{"[", "2", "]"}], "]"}], ",", RowBox[{"xTrue", "[", RowBox[{"[", "3", "]"}], "]"}],
                                   ",", "xhat", ",", "yhat", ",", "that", ",", "Ne", ",", "eps"}], "}"}]}], "]"}]}], ";"
                }]
              ], "]"}], ";"
            }]
          ], 
          RowBox[{"{", RowBox[{"t", ",", "0", ",", RowBox[{"T", "-", "1"}]}], "}"}]
        }], "]"}], ";"
    }]], "Input"],

  Cell["5. Export Results", "Section"],

  Cell[BoxData[
    RowBox[{
      RowBox[{"Export", "[",
        RowBox[{"\"Chapter8_Lesson4_results.csv\"", ",",
          RowBox[{"Prepend", "[", "hist", ",",
            RowBox[{"{", RowBox[{"\"t\"", ",", "\"true_x\"", ",", "\"true_y\"", ",", "\"true_th\"", ",", "\"est_x\"", ",", "\"est_y\"", ",", "\"est_th\"", ",", "\"Neff\"", ",", "\"eps\""}], "}"}]}], "]"}], ",",
          "\"CSV\""}], "]"}], ";",
      RowBox[{"Print", "[", "\"Saved: Chapter8_Lesson4_results.csv\"", "]"}], ";"
    }]], "Input"],

  Cell["6. Quick Plots", "Section"],

  Cell[BoxData[
    RowBox[{
      RowBox[{"tr", "=", RowBox[{"hist", "[", RowBox[{"[", RowBox[{"All", ",", RowBox[{"{", RowBox[{"2", ",", "3"}], "}"}]}], "]"}], "]"}]}], ";",
      RowBox[{"est", "=", RowBox[{"hist", "[", RowBox[{"[", RowBox[{"All", ",", RowBox[{"{", RowBox[{"5", ",", "6"}], "}"}]}], "]"}], "]"}]}], ";",
      RowBox[{"ListLinePlot", "[",
        RowBox[{
          RowBox[{"{", RowBox[{"tr", ",", "est"}], "}"}], ",",
          RowBox[{"PlotLegends", "->", RowBox[{"{", RowBox[{"\"true\"", ",", "\"estimate\""}], "}"}]}], ",",
          RowBox[{"PlotRange", "->", "All"}], ",",
          RowBox[{"AspectRatio", "->", "1"}]}], "]"}]
    }]], "Input"]
}]
