(* Chapter7_Lesson4.nb
   Wolfram Mathematica Notebook (plain-text form)
   Kalman-Filter Localization for AMR — Lesson 4
   Tuning Q/R using innovation log-likelihood and NIS.

   Open this file in Mathematica. If you prefer a true binary .nb, evaluate
   the Notebook expression below and then use "Save As..." in Mathematica.
*)

Notebook[{
  Cell["Chapter 7 — Lesson 4: Tuning Process/Measurement Noise for AMR", "Title"],
  Cell["EKF (unicycle + GPS) and innovation-based tuning (NIS).", "Text"],

  Cell[BoxData @ ToBoxes @ HoldForm[
    (* State and models *)
    x[k + 1] == f[x[k], u[k]] + w[k] &&
    z[k] == h[x[k]] + v[k]
  ], "Input"],

  Cell["Discrete-time EKF linearization:", "Text"],
  Cell[BoxData @ ToBoxes @ HoldForm[
    Pminus[k + 1] == F[k] . P[k] . Transpose[F[k]] + Q[k] &&
    S[k] == H[k] . Pminus[k] . Transpose[H[k]] + R[k]
  ], "Input"],

  Cell["Innovation negative log-likelihood (Gaussian):", "Text"],
  Cell[BoxData @ ToBoxes @ HoldForm[
    L == Sum[ Log[Det[S[k]]] + Transpose[nu[k]] . Inverse[S[k]] . nu[k], {k, 1, N}]
  ], "Input"],

  Cell["NIS definition and chi-square property:", "Text"],
  Cell[BoxData @ ToBoxes @ HoldForm[
    NIS[k] == Transpose[nu[k]] . Inverse[S[k]] . nu[k] &&
    NIS[k] \[Distributed] ChiSquareDistribution[m]
  ], "Input"],

  Cell["Small numeric example (simulate and compute mean NIS):", "Text"],
  Cell[BoxData @ ToBoxes @ HoldForm[
    SeedRandom[2];
    dt = 0.1;
    N = 600;
    (* True trajectory (simple) *)
    uTrue = Table[{1.0 + 0.2 Sin[0.2 k dt], 0.2 Sin[0.1 k dt]}, {k, 0, N - 1}];
    fStep[{px_, py_, th_}, {v_, w_}] := {px + v dt Cos[th], py + v dt Sin[th], Mod[th + w dt + Pi, 2 Pi] - Pi};
    xTrue = NestList[fStep[#, uTrue[[#2]]] &, {0, 0, 0}, Range[1, N - 1]];

    sigmaVMeas = 0.08; sigmaWMeas = 0.04; sigmaGps = 0.6;
    uMeas = uTrue + RandomVariate[NormalDistribution[0, 1], {N, 2}] * {sigmaVMeas, sigmaWMeas};
    zGps = xTrue[[All, {1, 2}]] + RandomVariate[NormalDistribution[0, sigmaGps], {N, 2}];

    (* Placeholder: implement EKF here, store nu and S, then compute mean NIS *)
    \"Implement EKF equations from lesson and compute NIS\"
  ], "Input"]
}]
