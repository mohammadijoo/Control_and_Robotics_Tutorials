(* Chapter10_Lesson3.nb *)
Notebook[{
  Cell["Chapter 10 — Scan Matching and Registration", "Title"],
  Cell["Lesson 3: Correlative Scan Matching", "Subtitle"],
  Cell["This notebook demonstrates 2D correlative scan matching on a synthetic occupancy grid map.", "Text"],

  Cell["1. Synthetic occupancy grid map", "Section"],
  Cell[BoxData[
    ToBoxes[
      Module[{res=0.05, sizeM=10., w, h, occ, cx, cy, rad},
        w = Round[sizeM/res]; h = w;
        occ = ConstantArray[0, {h, w}];
        occ[[1, ;;]] = 1; occ[[-1, ;;]] = 1; occ[[;;, 1]] = 1; occ[[;;, -1]] = 1;
        cx = Floor[w/2]; cy = Floor[h/2]; rad = Round[0.4/res];
        Do[occ[[r, c]] = 1, {r, cy-rad, cy+rad}, {c, cx-rad, cx+rad}];
        {res, occ}
      ]
    ]
  ], "Input"],

  Cell["2. Likelihood field via distance transform", "Section"],
  Cell[BoxData[
    ToBoxes[
      Module[{res, occ, sigma=0.10, distM, field},
        {res, occ} = %;
        distM = DistanceTransform[1 - occ] * res;
        field = Exp[-(distM^2)/(2 sigma^2)];
        field
      ]
    ]
  ], "Input"],

  Cell["3. Correlative score and discrete search", "Section"],
  Cell[BoxData[
    ToBoxes[
      Module[{field = %, res=0.05, x0=2.55, y0=3.05, th0=10 Degree,
              win=0.3, winTh=6 Degree, step=0.05, stepTh=1 Degree,
              ptsR, score, best},
        (* Create a simple synthetic scan by sampling occupied cells near a true pose *)
        ptsR = Module[{pTrue={2.4,3.2,18 Degree}, occPos, w=Length[field[[1]]], h=Length[field],
                       xs, ys, ptsW, dx, dy, ct, st, xr, yr, d, keep, noise=0.01},
          {ys, xs} = Position[Take[field, {1, -1, 2}, {1, -1, 2}] // Unitize, 1] // Transpose;
          xs = (xs - 1)*2; ys = (ys - 1)*2;
          ptsW = Transpose[{(xs+0.5)*res, (ys+0.5)*res}];
          dx = ptsW[[All,1]] - pTrue[[1]];
          dy = ptsW[[All,2]] - pTrue[[2]];
          ct = Cos[pTrue[[3]]]; st = Sin[pTrue[[3]]];
          xr = ct*dx + st*dy;
          yr = -st*dx + ct*dy;
          d = Sqrt[xr^2 + yr^2];
          keep = Pick[Range[Length[d]], UnitStep[d-0.3]*UnitStep[6.0-d], 1];
          Transpose[{xr[[keep]], yr[[keep]]}] + RandomVariate[NormalDistribution[0, noise], {Length[keep], 2}]
        ];

        score[{x_,y_,th_}] := Module[{ct=Cos[th], st=Sin[th], xw, yw, gx, gy, inside},
          xw = ct*ptsR[[All,1]] - st*ptsR[[All,2]] + x;
          yw = st*ptsR[[All,1]] + ct*ptsR[[All,2]] + y;
          gx = Floor[xw/res] + 1;
          gy = Floor[yw/res] + 1;
          inside = Pick[Range[Length[gx]], UnitStep[gx-1]*UnitStep[w-gx]*UnitStep[gy-1]*UnitStep[h-gy], 1];
          Total[field[[gy[[inside]], gx[[inside]]]]]
        ];

        best = MaximalBy[
          Flatten[
            Table[{x,y,th, score[{x,y,th}]},
              {x, x0-win, x0+win, step},
              {y, y0-win, y0+win, step},
              {th, th0-winTh, th0+winTh, stepTh}
            ], 2
          ],
          Last
        ][[1]];

        best
      ]
    ]
  ], "Input"],

  Cell["Output: {x, y, theta, score}", "Text"]
},
WindowSize -> {950, 700},
StyleDefinitions -> "Default.nb"
]
