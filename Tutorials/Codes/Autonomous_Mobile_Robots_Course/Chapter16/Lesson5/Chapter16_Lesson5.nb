(* Chapter16_Lesson5.nb
   Autonomous Mobile Robots — Chapter 16, Lesson 5
   Lab: Navigate Through Moving Crowds

   This notebook implements:
     - TTC for disc collision under constant relative velocity
     - A sampling-based crowd-aware DWA planner (2D unicycle approximation)
*)

Notebook[{

Cell["Chapter 16 — Lesson 5: Lab: Navigate Through Moving Crowds", "Title"],

Cell["1. Time-to-collision (TTC) for discs", "Section"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TTCDiscs", "[", 
   RowBox[{"pRel_", ",", "vRel_", ",", "R_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"a", ",", "b", ",", "c", ",", "disc", ",", "s", ",", "t1", ",", "t2"}], "}"}], ",",
    RowBox[{
     RowBox[{"a", "=", 
      RowBox[{"vRel", ".", "vRel"}]}], ";",
     RowBox[{"b", "=", 
      RowBox[{"2", 
       RowBox[{"pRel", ".", "vRel"}]}]}], ";",
     RowBox[{"c", "=", 
      RowBox[{
       RowBox[{"pRel", ".", "pRel"}], "-", 
       RowBox[{"R", "^", "2"}]}]}], ";",
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"c", "<=", "0"}], ",", 
       RowBox[{"Return", "[", "0", "]"}]}], "]"}], ";",
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"a", "<=", 
        RowBox[{"10", "^", 
         RowBox[{"-", "9"}]}]}], ",", 
       RowBox[{"Return", "[", "Infinity", "]"}]}], "]"}], ";",
     RowBox[{"disc", "=", 
      RowBox[{
       RowBox[{"b", "^", "2"}], "-", 
       RowBox[{"4", "a", "c"}]}]}], ";",
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"disc", "<", "0"}], ",", 
       RowBox[{"Return", "[", "Infinity", "]"}]}], "]"}], ";",
     RowBox[{"s", "=", 
      RowBox[{"Sqrt", "[", "disc", "]"}]}], ";",
     RowBox[{"t1", "=", 
      RowBox[{
       RowBox[{"-", "b"}], "-", "s"}], "/", 
      RowBox[{"(", 
       RowBox[{"2", "a"}], ")"}]}], ";",
     RowBox[{"t2", "=", 
      RowBox[{
       RowBox[{"-", "b"}], "+", "s"}], "/", 
      RowBox[{"(", 
       RowBox[{"2", "a"}], ")"}]}], ";",
     RowBox[{"Which", "[", 
      RowBox[{
       RowBox[{"t1", ">=", "0"}], ",", "t1", ",",
       RowBox[{"t2", ">=", "0"}], ",", "t2", ",",
       "True", ",", "Infinity"}], "]"}]
    }]}], "]"}]}]], "Input"],

Cell["2. Sampling-based crowd-aware planning (sketch)", "Section"],

Cell[TextData[{
 "We sample controls (v,w), roll out a unicycle model, and score trajectories with goal distance, clearance, TTC, and a social discomfort field around each human."
}], "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"UnicycleStep", "[", 
   RowBox[{"p_", ",", "th_", ",", "v_", ",", "w_", ",", "dt_"}], "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"p", "+", 
     RowBox[{"dt", " ", "v", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", "th", "]"}], ",", 
        RowBox[{"Sin", "[", "th", "]"}]}], "}"}]}]}], ",", 
    RowBox[{"th", "+", 
     RowBox[{"dt", " ", "w"}]}]}], "}"}]}]], "Input"],

Cell[TextData[{
 "For a full lab, implement the same sampling loop as in the Python/C++/Java versions and log trajectories for evaluation."
}], "Text"]

}, WindowSize -> {1000, 800}]
