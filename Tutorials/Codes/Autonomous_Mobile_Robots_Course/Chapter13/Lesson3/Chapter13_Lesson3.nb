(* Chapter13_Lesson3.nb *)
(* Visual–Inertial Fusion Pipelines (AMR Focus) *)

Notebook[{
  Cell["Chapter 13 - Lesson 3: Visual–Inertial Fusion Pipelines (AMR Focus)", "Title"],

  Cell["1. Symbolic IMU propagation Jacobian (planar)", "Section"],
  Cell[BoxData@ToBoxes@
    Module[{px, py, vx, vy, th, bax, bay, bg, axm, aym, wzm, dt, g0,
            aB, R, aW, f, x, J},
      x = {px, py, vx, vy, th, bax, bay, bg};
      aB = {axm - bax, aym - bay};
      R  = RotationMatrix[th];
      aW = R.aB + {0, -g0};
      f = {
        px + vx dt + (1/2) aW[[1]] dt^2,
        py + vy dt + (1/2) aW[[2]] dt^2,
        vx + aW[[1]] dt,
        vy + aW[[2]] dt,
        th + (wzm - bg) dt,
        bax, bay, bg
      };
      J = Simplify[D[f, {x}]];
      J
    ], "Input"],

  Cell["2. Pose measurement update (EKF) demonstration", "Section"],
  Cell[BoxData@ToBoxes@
    Module[{P, H, Rz, y, S, K, xhat},
      xhat = ConstantArray[0.0, 8];
      P = DiagonalMatrix[{0.5,0.5,0.2,0.2,0.3,0.2,0.2,0.1}^2];
      H = ConstantArray[0.0, {3,8}]; H[[1,1]]=1; H[[2,2]]=1; H[[3,5]]=1;
      Rz = DiagonalMatrix[{0.05^2, 0.05^2, 0.02^2}];
      y = {0.1, -0.05, 0.02};
      S = H.P.Transpose[H] + Rz;
      K = P.Transpose[H].Inverse[S];
      xhat = xhat + K.y;
      {xhat, Diagonal[P]}
    ], "Input"]
}, WindowTitle -> "Chapter13_Lesson3.nb"]
