(* ::Package:: *)

(* Chapter 5 — Odometry and Dead Reckoning
   Lesson 2: IMU Integration for Ground Robots

   Filename: Chapter5_Lesson2.nb

   This notebook derives key drift laws and provides a small numeric example.
*)

Notebook[{
  Cell["Chapter 5 / Lesson 2 — IMU Integration for Ground Robots", "Title"],
  Cell["Bias-induced drift (constant bias) — symbolic derivations", "Section"],
  Cell[BoxData[
    RowBox[{
      RowBox[{"(*", " 1D acceleration bias b_a:  v(t)=∫ b_a dt, p(t)=∫ v dt ", "*)"}], "\n",
      RowBox[{"ba", "=", "b_a"}], ";", "\n",
      RowBox[{"v", "[", "t_", "]", ":=", "Integrate[ba, {τ, 0, t}]"}], ";", "\n",
      RowBox[{"p", "[", "t_", "]", ":=", "Integrate[v[σ], {σ, 0, t}]"}], ";", "\n",
      RowBox[{"Simplify", "[", "v[t]", "]"}], "\n",
      RowBox[{"Simplify", "[", "p[t]", "]"}]
    }]], "Input"],
  Cell["Expected result: v(t)=b_a t, p(t)=(1/2) b_a t^2.", "Text"],

  Cell["Yaw gyro bias and cross-track error for constant forward speed", "Section"],
  Cell[BoxData[
    RowBox[{
      RowBox[{"(*", " yaw error eψ(t)=b_g t;  y_error(t) ≈ ∫ v sin(eψ) dt ≈ v ∫ b_g t dt ", "*)"}], "\n",
      RowBox[{"bg", "=", "b_g"}], ";", "\n",
      RowBox[{"v0", "=", "v"}], ";", "\n",
      RowBox[{"eyaw", "[", "t_", "]", ":=", "bg t"}], ";", "\n",
      RowBox[{"yerr", "[", "t_", "]", ":=", "Integrate[v0*Sin[eyaw[τ]], {τ, 0, t}]"}], ";", "\n",
      RowBox[{"Series", "[", "yerr[t]", ",", "{", "t", ",", "0", ",", "3", "}", "]"}]
    }]], "Input"],
  Cell["Small-angle gives y_error(t) ≈ (1/2) v b_g t^2 + O(t^4).", "Text"],

  Cell["Numeric example: integrate yaw with bias", "Section"],
  Cell[BoxData[
    RowBox[{
      RowBox[{"dt", "=", "0.01"}], ";",
      RowBox[{"T", "=", "20"}], ";",
      RowBox[{"n", "=", "Round[T/dt]"}], ";",
      RowBox[{"w0", "=", "0.2"}], ";",
      RowBox[{"bgval", "=", "0.01"}], ";",
      RowBox[{"yaw", "=", "0"}], ";",
      RowBox[{"yawTrue", "=", "0"}], ";",
      RowBox[{"errs", "=", "Table[", "\n",
        RowBox[{
          RowBox[{"yaw", "+=", "(w0 + bgval) dt"}], ";",
          RowBox[{"yawTrue", "+=", "w0 dt"}], ";",
          RowBox[{"wrap", "=", "ArcTan[Sin[yaw-yawTrue], Cos[yaw-yawTrue]]"}], ";",
          RowBox[{"wrap"}]
        }], ",", "{", "k", ",", "1", ",", "n", "}", "]"}], ";",
      RowBox[{"{", "Last[errs],", "Max[Abs[errs]]", "}"}]
    }]], "Input"],
  Cell["The yaw error grows approximately linearly with time under constant bias.", "Text"]
},
WindowTitle -> "Chapter5_Lesson2.nb"
]
