(* Chapter 11 - Lesson 5: Lab: EKF-SLAM in a Small World
   Autonomous Mobile Robots (Control Engineering)

   This is a compact Wolfram Language notebook (plain-text .nb) with EKF-SLAM core functions.
   Open in Mathematica and evaluate cells.
*)

Notebook[{
  Cell["Chapter 11 - Lesson 5: Lab: EKF-SLAM in a Small World", "Title"],
  Cell["Wolfram Language EKF-SLAM (joint-state) demo", "Subtitle"],

  Cell[BoxData[
    RowBox[{
      RowBox[{"wrapPi", "[", "a_", "]"}], ":=", 
      RowBox[{"Module", "[", 
        RowBox[{"{", RowBox[{"x", "=", "a"}], "}"}], ",", 
        RowBox[{
          RowBox[{"x", "=", 
            RowBox[{"Mod", "[", 
              RowBox[{
                RowBox[{"x", "+", "Pi"}], ",", 
                RowBox[{"2", " ", "Pi"}]}], "]"}]}], ";", 
          RowBox[{"x", "-", "Pi"}]}], "]"}]}]], "Input"],

  Cell["Motion model (unicycle): x' = f(x,u)", "Section"],
  Cell[BoxData[
    RowBox[{
      RowBox[{"motion", "[", 
        RowBox[{"x_", ",", "u_", ",", "dt_"}], "]"}], ":=", 
      RowBox[{"Module", "[", 
        RowBox[{"{", RowBox[{"px", ",", "py", ",", "th", ",", "v", ",", "w"}], "}"}], ",",
        RowBox[{
          RowBox[{"{", RowBox[{"px", ",", "py", ",", "th"}], "}"}], "=", "x", ";",
          RowBox[{"{", RowBox[{"v", ",", "w"}], "}"}], "=", "u", ";",
          RowBox[{"{",
            RowBox[{
              RowBox[{"px", "+", "v", " ", "dt", " ", 
                RowBox[{"Cos", "[", "th", "]"}]}], ",",
              RowBox[{"py", "+", "v", " ", "dt", " ", 
                RowBox[{"Sin", "[", "th", "]"}]}], ",",
              RowBox[{"wrapPi", "[", 
                RowBox[{"th", "+", "w", " ", "dt"}], "]"}]}], "}"}]}], "]"}]}]], "Input"],

  Cell["Measurement model (range-bearing): z = h(x, m)", "Section"],
  Cell[BoxData[
    RowBox[{
      RowBox[{"meas", "[", 
        RowBox[{"xr_", ",", "lm_"}], "]"}], ":=", 
      RowBox[{"Module", "[", 
        RowBox[{"{", RowBox[{"dx", ",", "dy", ",", "r", ",", "b"}], "}"}], ",",
        RowBox[{
          RowBox[{"dx", "=", 
            RowBox[{"lm", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "-", 
            RowBox[{"xr", "[", 
              RowBox[{"[", "1", "]"}], "]"}]}], ";",
          RowBox[{"dy", "=", 
            RowBox[{"lm", "[", 
              RowBox[{"[", "2", "]"}], "]"}], "-", 
            RowBox[{"xr", "[", 
              RowBox[{"[", "2", "]"}], "]"}]}], ";",
          RowBox[{"r", "=", 
            RowBox[{"Sqrt", "[", 
              RowBox[{"dx", "^", "2", "+", "dy", "^", "2"}], "]"}]}], ";",
          RowBox[{"b", "=", 
            RowBox[{"wrapPi", "[", 
              RowBox[{
                RowBox[{"ArcTan", "[", 
                  RowBox[{"dx", ",", "dy"}], "]"}], "-", 
                RowBox[{"xr", "[", 
                  RowBox[{"[", "3", "]"}], "]"}]}], "]"}]}], ";",
          RowBox[{"{", RowBox[{"r", ",", "b"}], "}"}]}], "]"}]}]], "Input"],

  Cell["EKF-SLAM loop (simplified): simulate and update", "Section"],
  Cell[BoxData[
    RowBox[{
      RowBox[{"(* Small world landmarks: id -> {x,y} *)"}], "\n",
      RowBox[{"landmarks", "=", 
        RowBox[{"<|", 
          RowBox[{
            RowBox[{"1", "->", 
              RowBox[{"{", RowBox[{"4.0", ",", "3.5"}], "}"}]}], ",",
            RowBox[{"2", "->", 
              RowBox[{"{", RowBox[{"8.5", ",", "1.5"}], "}"}]}], ",",
            RowBox[{"3", "->", 
              RowBox[{"{", RowBox[{"7.5", ",", "7.5"}], "}"}]}]}], "|>"}]}], ";"}]], "Input"],

  Cell[BoxData[
    RowBox[{
      RowBox[{"dt", "=", "0.1"}], ";", 
      RowBox[{"T", "=", "60"}], ";",
      RowBox[{"xgt", "=", 
        RowBox[{"{", RowBox[{"1.0", ",", "1.0", ",", 
          RowBox[{"20", " ", "Degree"}]}], "}"}]}], ";"}]], "Input"],

  Cell[BoxData[
    RowBox[{
      RowBox[{"traj", "=", 
        RowBox[{"NestList", "[", 
          RowBox[{
            RowBox[{"Function", "[", 
              RowBox[{"x", ",", 
                RowBox[{"motion", "[", 
                  RowBox[{"x", ",", 
                    RowBox[{"{", RowBox[{"0.7", ",", "0.1"}], "}"}], ",", "dt"}], "]"}]}], "]"}], ",",
            "xgt", ",", "T"}], "]"}]}], ";",
      RowBox[{"ListLinePlot", "[", 
        RowBox[{
          RowBox[{"traj", "[", 
            RowBox[{"[", 
              RowBox[{"All", ",", 
                RowBox[{"{", RowBox[{"1", ",", "2"}], "}"}]}], "]"}], "]"}], ",",
          RowBox[{"AspectRatio", "->", "1"}], ",",
          RowBox[{"GridLines", "->", "Automatic"}], ",",
          RowBox[{"PlotLabel", "->", "\"Ground-truth trajectory (demo)\""}]}], "]"}]}]], "Input"]
},
WindowSize -> {1100, 750},
WindowMargins -> {{Automatic, 50}, {Automatic, 50}}
]
