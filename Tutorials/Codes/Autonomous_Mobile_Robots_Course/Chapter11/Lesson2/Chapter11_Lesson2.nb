(* ::Package:: *)

(* Chapter 11 - SLAM I (Filter-Based SLAM)
   Lesson 2: EKF-SLAM (structure and limitations)

   This notebook demonstrates:
   - Range-bearing measurement model
   - Symbolic Jacobian for EKF measurement update
   - A single EKF update step (numeric)

   Note: This is a plain-text .nb representation using Wolfram Language.
*)

ClearAll["Global`*"];

WrapAngle[a_] := Module[{b = Mod[a + Pi, 2 Pi] - Pi}, b];

(* State: {x, y, theta, mx, my} for one landmark *)
h[{x_, y_, th_, mx_, my_}] := Module[{dx = mx - x, dy = my - y, r, b},
  r = Sqrt[dx^2 + dy^2];
  b = WrapAngle[ArcTan[dx, dy] - th]; (* ArcTan[x,y] is atan2(y,x) *)
  {r, b}
];

xSym = {x, y, th, mx, my};
Hsym = D[h[xSym], {xSym}];  (* 2x5 Jacobian *)
Hsym // MatrixForm

(* Numeric example *)
mu = {0.0, 0.0, 0.0, 5.0, 1.0};
P  = DiagonalMatrix[{0.1^2, 0.1^2, (5 Degree)^2, 0.5^2, 0.5^2}];
R  = DiagonalMatrix[{0.15^2, (3 Degree)^2}];

z = {Sqrt[(5 - 0)^2 + (1 - 0)^2] + 0.05, 0.2}; (* fake measurement *)

zhat = h[mu];
H = Hsym /. Thread[xSym -> mu];

innov = {z[[1]] - zhat[[1]], WrapAngle[z[[2]] - zhat[[2]]]};
S = H.P.Transpose[H] + R;
K = P.Transpose[H].Inverse[S];

muNew = mu + K.innov;
muNew[[3]] = WrapAngle[muNew[[3]]];

(* Joseph-form covariance update *)
I = IdentityMatrix[Length[mu]];
PNew = (I - K.H).P.Transpose[I - K.H] + K.R.Transpose[K];

{muNew, PNew} // Short
