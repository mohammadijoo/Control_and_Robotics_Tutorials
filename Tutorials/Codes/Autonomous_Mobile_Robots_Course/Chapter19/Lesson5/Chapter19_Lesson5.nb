(* Chapter19_Lesson5.nb *)
(* Wolfram Language script content for notebook use *)
ClearAll["Global`*"];
readRuns[file_] := Rest[Import[file, "CSV"]];
q[x_, p_] := Quantile[x, p];
mean[x_] := Mean[x];
aggregate[file_] := Module[{r = readRuns[file], t, succ, spl, col, ate, rpe, clr, eper, cm, cp},
  succ = ToExpression[r[[All, 3]]];
  t    = ToExpression[r[[All, 4]]];
  spl  = Table[If[succ[[i]] == 1, ToExpression[r[[i, 6]]]/Max[ToExpression[r[[i, 5]]], 10^-9], 0.0], {i, Length[r]}];
  col  = Boole[ToExpression[r[[All, 7]]] > 0];
  clr  = ToExpression[r[[All, 8]]];
  ate  = ToExpression[r[[All, 10]]];
  rpe  = ToExpression[r[[All, 11]]];
  eper = ToExpression[r[[All, 9]]]/Map[Max[#, 10^-9] &, ToExpression[r[[All, 5]]]];
  cm   = ToExpression[r[[All, 12]]];
  cp   = ToExpression[r[[All, 13]]];
  <|"success_rate" -> mean[succ], "spl" -> mean[spl], "collision_rate" -> mean[col],
    "time_mean_s" -> mean[t], "ate_rmse_mean_m" -> mean[ate], "rpe_rmse_mean_m" -> mean[rpe],
    "clearance_p10_m" -> q[clr, 0.1], "energy_per_m_mean" -> mean[eper], "cpu_mean_ms" -> mean[cm], "cpu_p95_ms" -> mean[cp]|>
];
Print[Dataset[{<|"System" -> "Baseline"|> ~Join~ aggregate["baseline_example.csv"], <|"System" -> "Candidate"|> ~Join~ aggregate["candidate_example.csv"]}]];
