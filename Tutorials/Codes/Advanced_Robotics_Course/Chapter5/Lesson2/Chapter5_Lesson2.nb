clearAll[unicyclePrimitive];

unicyclePrimitive[v_, omega_, T_] := Module[
  {x, y, th, sol, xT, yT, thT},
  sol = NDSolve[
    {
      x'[t] == v Cos[th[t]],
      y'[t] == v Sin[th[t]],
      th'[t] == omega,
      x[0] == 0, y[0] == 0, th[0] == 0
    },
    {x, y, th}, {t, 0, T}
  ];
  xT = x[T] /. sol[[1]];
  yT = y[T] /. sol[[1]];
  thT = Mod[th[T] /. sol[[1]], 2 Pi];
  <|"v" -> v, "omega" -> omega, "T" -> T,
    "disp" -> {xT, yT, thT}|>
]

(* Generate a small library *)
primitiveLibrary = Table[
  unicyclePrimitive[v, omega, 1.0],
  {v, {1.0}},
  {omega, {0.0, 0.8, -0.8}}
] // Flatten;

primitiveLibrary
      
