L1 = 1.0; L2 = 1.0;
pDes = {1.0, 1.0};

fk[{th1_, th2_}] := {
  L1*Cos[th1] + L2*Cos[th1 + th2],
  L1*Sin[th1] + L2*Sin[th1 + th2]
};

projectPlanar2R[qInit_List] := Module[
  {th1, th2, sol},
  sol = FindRoot[
    fk[{th1, th2}] == pDes,
    { {th1, qInit[[1]]}, {th2, qInit[[2]]} }
  ];
  {th1, th2} /. sol
]

qProj = projectPlanar2R[{0.1, 0.2}];
N[{qProj, fk[qProj]}]
      
