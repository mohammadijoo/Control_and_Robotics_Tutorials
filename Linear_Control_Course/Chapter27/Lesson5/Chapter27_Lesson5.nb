(* Controller gains *)
Kp = 3.2;
Ki = 9.0;

(* System of ODEs *)
eqs = {
   z'[t] == 1 - y[t], (* r(t) = 1 *)
   y'[t] == -y[t] + Kp (1 - y[t]) + Ki z[t] +
     Piecewise[{ {0, t < 3}, {0.2, t >= 3} }] (* disturbance d(t) *)
   };

ics = {z[0] == 0, y[0] == 0};

sol = NDSolve[
   Join[eqs, ics],
   {z, y},
   {t, 0, 8}
   ][[1]];

Plot[Evaluate[y[t] /. sol], {t, 0, 8},
 PlotRange -> All,
 AxesLabel -> {"t", "y(t)"},
 PlotLabel -> "PI tracking with disturbance step at t = 3 s"]
