Clear[theta, omega, u, m, L, b, g];

x = {theta, omega};

f = {
   omega,
   -(b/(m L^2)) omega - (g/L) Sin[theta] + u/(m L^2)
   };

(* Jacobians *)
A = D[f, {x}];
B = D[f, {u}];

(* Operating point: hanging down *)
thetaOp = 0;
omegaOp = 0;
uOp     = 0;

Aop = A /. {theta -> thetaOp, omega -> omegaOp, u -> uOp};
Bop = B /. {theta -> thetaOp, omega -> omegaOp, u -> uOp};

MatrixForm[Aop]
MatrixForm[Bop]
