Tp = 0.15;
KpProc = 1.0;
uMin = -5; uMax = 5;
Kp = 8; Ki = 20;
rStep = 1.0;

sat[u_] := Min[Max[u, uMin], uMax];

(* Continuous-time clamped integrator dynamics *)
sys = NDSolve[
   {
    y'[t] == (-1/Tp) y[t] + (KpProc/Tp) u[t],
    xI'[t] == Which[
      u[t] == uMax && (rStep - y[t]) > 0, 0,
      u[t] == uMin && (rStep - y[t]) < 0, 0,
      True, (rStep - y[t])
    ],
    v[t] == Kp (rStep - y[t]) + Ki xI[t],
    u[t] == sat[v[t]],
    y[0] == 0, xI[0] == 0
   },
   {y, xI, u, v},
   {t, 0, 1.5}
];

ySol[t_] := Evaluate[y[t] /. sys[[1]]];
