(* Physical parameters *)
M  = 1.0;
B  = 0.5;
K  = 4.0;
Kp = 16.0;
Kd = 4.0;
r0 = 1.0;

(* Closed-loop differential equation:
   M y''(t) + (B + Kd) y'(t) + (K + Kp) y(t) == Kp r0 *)
eqn = M y''[t] + (B + Kd) y'[t] + (K + Kp) y[t] == Kp r0;

ics = {y[0] == 0, y'[0] == 0};

sol = NDSolve[{eqn, ics}, y, {t, 0, 10}];

Plot[Evaluate[y[t] /. sol], {t, 0, 10},
     PlotRange -> All,
     AxesLabel -> {"t", "y(t)"},
     GridLines -> Automatic,
     PlotLegends -> {"PD step response"}]
