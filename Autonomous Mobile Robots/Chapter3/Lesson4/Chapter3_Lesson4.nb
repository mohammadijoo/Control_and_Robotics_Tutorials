\
Notebook[{
  Cell["Chapter 3 \[LongDash] Lesson 4: Motion Primitives for Ground Vehicles (conceptual use)", "Title"],
  Cell["Symbolic endpoint derivation for constant-curvature primitives.", "Text"],
  Cell[BoxData@ToBoxes[
    HoldForm[
      ClearAll[v, kappa, T];
      theta[t_] := v kappa t;
      dx = FullSimplify[Integrate[v Cos[theta[t]], {t, 0, T}]];
      dy = FullSimplify[Integrate[v Sin[theta[t]], {t, 0, T}]];
      dtheta = FullSimplify[theta[T]];
      {dx, dy, dtheta}
    ]
  ], "Input"]
},
WindowSize -> {1000, 800},
StyleDefinitions -> "Default.nb"
]
