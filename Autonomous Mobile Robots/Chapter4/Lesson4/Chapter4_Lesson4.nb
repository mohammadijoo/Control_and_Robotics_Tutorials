(* Chapter4_Lesson4.nb
Autonomous Mobile Robots (Control Engineering)
Chapter 4: Mobile Robot Dynamics (Applied)
Lesson 4: Stability and Tip-Over Risk (vehicle view)

Wolfram Language content (can be pasted into a notebook).
*)

ClearAll["Global`*"];

(* Parameters *)
g = 9.81;
track = 0.55;        (* T *)
wheelbase = 0.65;    (* L *)
h = 0.25;            (* CoG height *)
mu = 0.70;

aTipY = g*(track/(2 h));
aMu = mu*g;

Print["aTipY = ", N[aTipY], " m/s^2"];
Print["mu*g  = ", N[aMu], " m/s^2"];

(* LTR definitions *)
LTRy[aY_] := 2 h aY/(g track);
LTRx[aX_] := 2 h aX/(g wheelbase);

(* Quasi-static tipping threshold proof via moment balance *)
(* Tip about outer wheel: mg*(T/2) - m*aY*h = 0 -> aY = g*T/(2h) *)
Assuming[{g > 0, track > 0, h > 0, m > 0},
 Simplify[Solve[m g (track/2) - m aY h == 0, aY]]
]

(* Trajectory example *)
t = Subdivide[0, 12, 600];
v[t_] := Clip[0.2 + 1.4 (1 - Exp[-t/2.5]) (1 - 0.4 Boole[t > 8] (t - 8)/4), {0, 1.8}];
kappa[t_] := 0.05 + 0.35 Exp[-((t - 6)/2)^2];

aY = (v /@ t)^2 * (kappa /@ t);
LTR = LTRy /@ aY;
minMarginTipY = Min[1 - Abs /@ LTR];

Print["Min margin_tip_y = ", N[minMarginTipY]];

(* Safe speed bounds along curvature *)
kAbs = Max[Abs[kappa /@ t], 10^-9] & /@ t; (* pointwise safe *)
vTip = Sqrt[aTipY / kAbs];
vSlide = Sqrt[aMu / kAbs];
vSafe = MapThread[Min, {vTip, vSlide}];

ListLinePlot[{Transpose[{t, v /@ t}], Transpose[{t, vSafe}]},
 PlotLegends -> {"v(t)", "vSafe(t)"},
 Frame -> True, FrameLabel -> {"t [s]", "speed [m/s]"}]

ListLinePlot[Transpose[{t, LTR}],
 PlotLegends -> {"LTRy"}, Frame -> True, FrameLabel -> {"t [s]", "LTRy"}]
